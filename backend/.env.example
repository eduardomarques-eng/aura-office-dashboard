# ══════════════════════════════════════════════════════════
# Aura Decore — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no git!
# ══════════════════════════════════════════════════════════

# ── LLM APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Opus 4.7 (IVE/GUARD) + Sonnet 4.6 (demais)
GROQ_API_KEY=gsk_...                  # Llama 3.3 70B — primário, gratuito

# ── Ollama (fallback local) ────────────────────────────────
OLLAMA_URL=http://localhost:11434     # padrão — não mudar se local
OLLAMA_MODEL=llama3.2                 # modelo local

# ── Shopify ───────────────────────────────────────────────
SHOPIFY_DOMAIN=auradecore.myshopify.com   # domínio customizado: auradecore.com.br
STORE_DOMAIN=auradecore.com.br
SHOPIFY_ADMIN_TOKEN=shpat_...         # Admin API Token

# ── Meta (Facebook/Instagram) ─────────────────────────────
FB_PAGE_ID=1130358240160979           # Página "Aura Decore" — NÃO mudar!
FB_PAGE_TOKEN=EAA...                  # Token de página (nunca expira)
META_PIXEL_ID=                        # ID do Pixel Meta (Gerenciador de Eventos)
META_CAPI_TOKEN=EAA...               # Conversions API token (Pixel → Settings → CAPI)
META_ACCESS_TOKEN=EAA...             # Token de acesso do usuário (Business Manager)
META_BUSINESS_ID=                    # ID do Business Manager

# ── WhatsApp (Z-API) ──────────────────────────────────────
ZAPI_INSTANCE_ID=                     # ID da instância Z-API
ZAPI_TOKEN=                           # Token da instância
ZAPI_CLIENT_TOKEN=                    # Client Token

# ── Pagamentos ────────────────────────────────────────────
APPMAX_TOKEN=                         # Token AppMax (gateway)

# ── Dropshipping ──────────────────────────────────────────
DROPI_TOKEN=                          # Token Dropi (opcional — maioria manual)

# ── Instagram Business (publicação automática) ────────────
# Obter: GET /{fb_page_id}?fields=instagram_business_account&access_token={FB_PAGE_TOKEN}
IG_USER_ID=                           # Instagram Business Account ID

# ── Vault Obsidian ────────────────────────────────────────
OBSIDIAN_VAULT=C:\Users\erick\AURA-decor-vault

# ── n8n Cloud ─────────────────────────────────────────────
N8N_WEBHOOK_URL=https://seu-n8n.app.n8n.cloud/webhook
N8N_API_KEY=                          # API Key do n8n cloud (opcional)

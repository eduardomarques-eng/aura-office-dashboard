{% comment %} Aura Decore: Urgência — Poucos em estoque {% endcomment %}
{% if product.available %}
  {% assign total_inventory = 0 %}
  {% assign is_tracked = false %}
  {% for variant in product.variants %}
    {% if variant.inventory_management == 'shopify' %}
      {% assign total_inventory = total_inventory | plus: variant.inventory_quantity %}
      {% assign is_tracked = true %}
    {% endif %}
  {% endfor %}

  {% comment %} Se não for rastreado, simula um estoque baixo baseado no ID do produto para manter consistência {% endcomment %}
  {% if is_tracked == false %}
    {% assign mock_seed = product.id | modulo: 7 | plus: 3 %}
    {% assign total_inventory = mock_seed %}
  {% endif %}

  {% if total_inventory > 0 and total_inventory <= 10 %}
    <div class="aura-urgency-badge">
      🔥 Apenas {{ total_inventory }} unidades em estoque!
    </div>
  {% elsif total_inventory > 10 and total_inventory <= 20 %}
    <div class="aura-urgency-badge">
      ⚡ Últimas unidades disponíveis!
    </div>
  {% endif %}
{% endif %}

{% comment %} Aura Decore: Social Proof Counter {% endcomment %}
<div id="aura-viewers" style="display:none;font-size:12.5px;color:var(--aura-stone,#8A8680);margin:8px 0;font-family:var(--aura-font-ui);letter-spacing:0.04em;text-transform:uppercase;">
  👁 <span id="aura-viewer-count" style="font-weight:600;color:var(--aura-primary);">0</span> pessoas estão vendo este produto agora
</div>

<script>
(function() {
  const count = Math.floor(Math.random() * 25) + 6; // 6-30 pessoas
  const el = document.getElementById('aura-viewer-count');
  const wrap = document.getElementById('aura-viewers');
  if (el && wrap) {
    el.textContent = count;
    wrap.style.display = 'block';
    
    setInterval(function() {
      if (Math.random() > 0.6) {
        const curr = parseInt(el.textContent);
        const change = Math.random() > 0.5 ? 1 : -1;
        const nextVal = curr + change;
        if (nextVal >= 4 && nextVal <= 35) {
          el.textContent = nextVal;
        }
      }
    }, 12000);
  }
})();
</script>

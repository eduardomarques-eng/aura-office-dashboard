{% comment %}
  Aura Decore — Newsletter Minimalista
  Input underline, sem bordas, copy contemplativo
  Sprint 3
{% endcomment %}

<section class="email-signup" id="AuraNewsletter-{{ section.id }}">
  <div style="max-width:64rem;margin:0 auto;">

    {%- if section.settings.kicker != blank -%}
      <span class="kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
    <h2 data-aura-reveal style="font-family:var(--font-serif);font-size:clamp(2.4rem,4vw,4.2rem);font-weight:400;line-height:1.1;letter-spacing:.01em;color:var(--aura-grafite);margin-bottom:1.6rem;">
      {{ section.settings.heading }}
    </h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
    <p style="font-family:var(--font-sans);font-size:1.5rem;font-weight:300;line-height:1.8;color:var(--aura-cinza);margin-bottom:4rem;max-width:44rem;margin-left:auto;margin-right:auto;">
      {{ section.settings.subheading }}
    </p>
    {%- endif -%}

    {%- form 'customer', id: 'aura-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,aura-decore">

      <div style="display:flex;gap:1.6rem;max-width:48rem;margin:0 auto;align-items:flex-end;">
        <div style="flex:1;">
          <label for="NewsletterEmail-{{ section.id }}" style="display:block;font-family:var(--font-sans);font-size:1.1rem;letter-spacing:.14em;text-transform:uppercase;color:var(--aura-cinza);margin-bottom:.8rem;">
            {{ section.settings.email_label | default: 'Seu e-mail' }}
          </label>
          <input
            type="email"
            name="contact[email]"
            id="NewsletterEmail-{{ section.id }}"
            placeholder="{{ section.settings.email_placeholder | default: 'voce@email.com' }}"
            required
            autocorrect="off"
            autocapitalize="off"
            style="width:100%;background:transparent;border:none;border-bottom:1px solid var(--aura-grafite);border-radius:0;padding:.8rem 0;font-family:var(--font-sans);font-size:1.5rem;font-weight:300;color:var(--aura-grafite);outline:none;transition:border-color .2s;"
          >
        </div>
        <button type="submit" class="button newsletter-form__button">
          {{ section.settings.button_label | default: 'Entrar' }}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
      <p style="margin-top:2rem;font-family:var(--font-sans);font-size:1.3rem;color:var(--aura-musgo);letter-spacing:.04em;">
        ✓ {{ section.settings.success_message | default: 'Bem-vindo(a) ao universo Aura Decore.' }}
      </p>
      {%- endif -%}

    {%- endform -%}

    {%- if section.settings.fine_print != blank -%}
    <p style="margin-top:2rem;font-size:1.1rem;color:var(--aura-cinza);opacity:.7;letter-spacing:.04em;">
      {{ section.settings.fine_print }}
    </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Aura Newsletter",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Fique próximo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Receba a curadoria Aura Decore"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Novidades, inspirações e chegadas exclusivas — sem ruído."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Label do campo",
      "default": "Seu e-mail"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder",
      "default": "voce@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão",
      "default": "Assinar"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensagem de sucesso",
      "default": "Bem-vindo(a) ao universo Aura Decore."
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Nota de rodapé",
      "default": "Sem spam. Cancele quando quiser."
    }
  ],
  "presets": [
    {
      "name": "Aura Newsletter",
      "settings": {
        "kicker": "Fique próximo",
        "heading": "Receba a curadoria Aura Decore",
        "subheading": "Novidades, inspirações e chegadas exclusivas — sem ruído."
      }
    }
  ]
}
{% endschema %}

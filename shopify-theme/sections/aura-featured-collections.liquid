{% comment %}
  Aura Decore — Featured Collections Grid
  Estrutura inspirada na Dcorada: 1 destaque grande + 2 laterais + 3 na base
  Sprint 3
{% endcomment %}

{%- if section.settings.heading != blank or section.settings.kicker != blank -%}
<div class="aura-section-title" data-aura-reveal>
  <h2>{{ section.settings.heading | default: 'Nossas Coleções' }}</h2>
</div>
{%- endif -%}

<div class="aura-colecoes-grid" id="AuraCollections-{{ section.id }}">

  {%- for block in section.blocks -%}
    {%- assign col = block.settings -%}
    {%- if col.collection != blank -%}
      {%- assign coll = collections[col.collection] -%}
    {%- endif -%}

    <a
      href="{{ coll.url | default: col.link | default: '/collections/all' }}"
      class="aura-col-card aura-stagger__item"
      {{ block.shopify_attributes }}
    >
      {%- if col.image != blank -%}
        <img
          src="{{ col.image | image_url: width: 800 }}"
          srcset="
            {{ col.image | image_url: width: 400 }} 400w,
            {{ col.image | image_url: width: 800 }} 800w,
            {{ col.image | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 749px) 50vw, (max-width: 1023px) 50vw, 33vw"
          alt="{{ col.image.alt | default: coll.title | default: col.custom_title }}"
          width="800" height="1000"
          loading="lazy"
          class="aura-col-card__img"
        >
      {%- elsif coll != blank and coll.featured_image -%}
        <img
          src="{{ coll.featured_image | image_url: width: 800 }}"
          alt="{{ coll.title }}"
          width="800" height="1000"
          loading="lazy"
          class="aura-col-card__img"
        >
      {%- else -%}
        <div style="width:100%;height:100%;background:var(--aura-linen);"></div>
      {%- endif -%}

      <div class="aura-col-card__overlay"></div>

      <div class="aura-col-card__label">
        <span class="aura-col-card__label-title">
          {{ col.custom_title | default: coll.title | default: 'Coleção' }}
        </span>
        {%- if col.subtitle != blank -%}
          <span class="aura-col-card__label-count">{{ col.subtitle }}</span>
        {%- elsif coll != blank -%}
          <span class="aura-col-card__label-count">{{ coll.products_count }} peças</span>
        {%- endif -%}
      </div>
    </a>
  {%- endfor -%}

  {%- if section.blocks.size == 0 -%}
    {%- assign fallback_cols = collections | sort: 'published_at' | reverse | slice: 0, 6 -%}
    {%- for coll in fallback_cols -%}
    <a href="{{ coll.url }}" class="aura-col-card">
      {%- if coll.featured_image -%}
        <img src="{{ coll.featured_image | image_url: width: 800 }}" alt="{{ coll.title }}" loading="lazy" class="aura-col-card__img">
      {%- else -%}
        <div style="width:100%;height:100%;background:var(--aura-linen);"></div>
      {%- endif -%}
      <div class="aura-col-card__overlay"></div>
      <div class="aura-col-card__label">
        <span class="aura-col-card__label-title">{{ coll.title }}</span>
        <span class="aura-col-card__label-count">{{ coll.products_count }} peças</span>
      </div>
    </a>
    {%- endfor -%}
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Aura Coleções Grid",
  "tag": "section",
  "class": "spaced-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Curadoria Aura Decore"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Nossas Coleções"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Card de Coleção",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem personalizada (opcional)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Título personalizado (opcional)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo / contagem"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (se sem coleção)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aura Coleções Grid",
      "blocks": [
        { "type": "collection_card", "settings": { "custom_title": "Chegadas | Novidades", "subtitle": "Recém chegados" } },
        { "type": "collection_card", "settings": { "custom_title": "Botânica Seca", "subtitle": "A natureza que permanece" } },
        { "type": "collection_card", "settings": { "custom_title": "Aromáticos & Velas", "subtitle": "Rituais sensíveis" } },
        { "type": "collection_card", "settings": { "custom_title": "Mais Amados", "subtitle": "Favoritos da comunidade" } },
        { "type": "collection_card", "settings": { "custom_title": "Destaque da Estação", "subtitle": "Curadoria sazonal" } }
      ]
    }
  ]
}
{% endschema %}

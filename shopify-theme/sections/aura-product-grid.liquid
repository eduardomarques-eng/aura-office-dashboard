{% comment %}
  Aura Decore — Product Grid Section
  4 colunas desktop, 2 mobile | com GSAP stagger
  Sprint 3
{% endcomment %}

<section class="aura-product-grid-section" id="AuraProductGrid-{{ section.id }}">

  {%- if section.settings.heading != blank -%}
  <div class="aura-section-title" data-aura-reveal>
    {%- if section.settings.kicker != blank -%}
      <span class="kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="body-text" style="text-align:center;margin-top:1.2rem;">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
  {%- endif -%}

  {%- assign source_collection = collections[section.settings.collection] -%}
  {%- assign products_to_show = section.settings.products_to_show | default: 8 -%}

  {%- if source_collection != blank -%}
    {%- assign product_list = source_collection.products -%}
  {%- else -%}
    {%- assign product_list = collections.all.products -%}
  {%- endif -%}

  <div class="aura-product-grid product-grid" id="AuraPGrid-{{ section.id }}">
    {%- for product in product_list limit: products_to_show -%}
    <div class="card-wrapper aura-fade-up" style="--reveal-delay: {{ forloop.index0 | times: 80 }}ms">
      <a href="{{ product.url }}" class="card card--product">

        <div class="card__media aura-hover-zoom" style="aspect-ratio:4/5;overflow:hidden;">
          {%- if product.featured_media -%}
            <img
              src="{{ product.featured_media | image_url: width: 600 }}"
              srcset="
                {{ product.featured_media | image_url: width: 400 }} 400w,
                {{ product.featured_media | image_url: width: 600 }} 600w,
                {{ product.featured_media | image_url: width: 800 }} 800w
              "
              sizes="(max-width: 749px) 50vw, 25vw"
              alt="{{ product.featured_media.alt | default: product.title }}"
              width="600" height="750"
              loading="lazy"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--aura-linen);"></div>
          {%- endif -%}

          {%- if product.compare_at_price > product.price -%}
            <span class="badge badge--on-sale">Sale</span>
          {%- endif -%}
          {%- unless product.available -%}
            <span class="badge badge--sold-out">Esgotado</span>
          {%- endunless -%}
        </div>

        <div class="card__content">
          {%- if product.vendor != blank and section.settings.show_vendor -%}
            <span class="caption" style="text-transform:uppercase;letter-spacing:.12em;">{{ product.vendor }}</span>
          {%- endif -%}

          <h3 class="card__heading">{{ product.title | truncate: 60 }}</h3>

          <div class="price price--container" style="margin-top:.8rem;">
            {%- if product.compare_at_price > product.price -%}
              <del style="color:var(--aura-cinza);margin-right:.8rem;">{{ product.compare_at_price | money }}</del>
              <span class="price--sale">{{ product.price | money }}</span>
            {%- else -%}
              {{ product.price | money }}
            {%- endif -%}
          </div>
        </div>

      </a>

      {%- if section.settings.show_quick_add and product.available -%}
      <div class="quick-add">
        <form action="/cart/add" method="post">
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
          <button type="submit" class="button" style="width:100%;margin-top:.8rem;">
            {{ section.settings.quick_add_label | default: 'Adicionar ao carrinho' }}
          </button>
        </form>
      </div>
      {%- endif -%}

    </div>
    {%- endfor -%}

    {%- if product_list.size == 0 -%}
    <p style="grid-column:1/-1;text-align:center;color:var(--aura-cinza);padding:6.4rem;">Nenhum produto encontrado.</p>
    {%- endif -%}
  </div>

  {%- if section.settings.show_view_all and source_collection != blank -%}
  <div style="text-align:center;margin-top:4.8rem;">
    <a href="{{ source_collection.url }}" class="button button--secondary">
      {{ section.settings.view_all_label | default: 'Ver todos' }}
    </a>
  </div>
  {%- endif -%}

</section>

<style>
  .aura-product-grid-section { padding: var(--section-gap-desktop) 0; }
  #AuraPGrid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 0.8rem;
    padding: 0 var(--s-48);
    margin-top: 4rem;
  }
  @media (max-width: 1023px) {
    #AuraPGrid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); padding: 0 var(--s-24); }
  }
  @media (max-width: 749px) {
    #AuraPGrid-{{ section.id }} { padding: 0 var(--s-16); gap: var(--s-8); }
  }
</style>

{% schema %}
{
  "name": "Aura Grid de Produtos",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título da seção",
      "default": "Mais Amados"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Os favoritos da nossa comunidade."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção fonte"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4, "max": 12, "step": 4,
      "label": "Número de produtos",
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2, "max": 5, "step": 1,
      "label": "Colunas (desktop)",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Mostrar fornecedor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Botão adicionar ao carrinho",
      "default": true
    },
    {
      "type": "text",
      "id": "quick_add_label",
      "label": "Texto do botão quick add",
      "default": "Adicionar ao carrinho"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar link \"Ver todos\"",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Texto \"Ver todos\"",
      "default": "Ver coleção completa"
    }
  ],
  "presets": [
    {
      "name": "Aura Grid de Produtos",
      "settings": {
        "heading": "Mais Amados",
        "kicker": "Os favoritos",
        "products_to_show": 8,
        "columns_desktop": 4
      }
    }
  ]
}
{% endschema %}

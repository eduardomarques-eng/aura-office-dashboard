{% comment %}Aura Cookie Consent v1 — Banner LGPD/GDPR minimalista — Sprint 11{% endcomment %}

{%- if section.settings.enabled -%}
<div class="aura-cookie" id="AuraCookie-{{ section.id }}" role="dialog" aria-label="Aviso de cookies" aria-live="polite" hidden>
  <div class="aura-cookie__inner">
    <div class="aura-cookie__text">
      <p class="aura-cookie__message">
        {{ section.settings.message | default: 'Usamos cookies para melhorar sua experiência. Ao continuar navegando, você concorda com nossa' }}
        {%- if section.settings.policy_url != blank -%}
          <a href="{{ section.settings.policy_url }}" class="aura-cookie__link">{{ section.settings.policy_label | default: 'Política de Privacidade' }}</a>.
        {%- endif -%}
      </p>
    </div>
    <div class="aura-cookie__actions">
      {%- if section.settings.show_decline -%}
      <button class="aura-cookie__decline" id="AuraCookieDecline-{{ section.id }}">{{ section.settings.decline_label | default: 'Recusar' }}</button>
      {%- endif -%}
      <button class="aura-cookie__accept" id="AuraCookieAccept-{{ section.id }}">{{ section.settings.accept_label | default: 'Aceitar' }}</button>
    </div>
  </div>
</div>

<style>
.aura-cookie {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9989;
  background: var(--aura-grafite, #3D3D3B);
  border-top: 2px solid var(--aura-terracota, #B8793A);
  transform: translateY(100%);
  transition: transform .4s cubic-bezier(.4,0,.2,1);
}
.aura-cookie:not([hidden]) { transform: translateY(0); }
.aura-cookie__inner {
  max-width: var(--page-width, 144rem);
  margin: 0 auto;
  padding: 1.8rem 4.8rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2.4rem;
  flex-wrap: wrap;
}
@media (max-width: 749px) { .aura-cookie__inner { padding: 1.6rem 2rem; } }
.aura-cookie__message {
  font-family: var(--font-body-family);
  font-size: 1.3rem;
  font-weight: 300;
  color: rgba(250,250,248,.8);
  line-height: 1.6;
  margin: 0;
}
.aura-cookie__link {
  color: var(--aura-terracota, #B8793A);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.aura-cookie__actions {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  flex-shrink: 0;
}
.aura-cookie__accept {
  background: var(--aura-terracota, #B8793A);
  color: #fff;
  border: none;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 1rem 2.4rem;
  cursor: pointer;
  transition: background .25s ease;
}
.aura-cookie__accept:hover { background: #a06830; }
.aura-cookie__decline {
  background: transparent;
  border: 1px solid rgba(250,250,248,.3);
  color: rgba(250,250,248,.6);
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 300;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: 1rem 1.8rem;
  cursor: pointer;
  transition: border-color .25s ease, color .25s ease;
}
.aura-cookie__decline:hover { border-color: rgba(250,250,248,.6); color: rgba(250,250,248,.9); }
@media(prefers-reduced-motion:reduce){ .aura-cookie { transition:none!important; } }
</style>

<script>
(function(){
  var COOKIE_KEY = 'aura_cookie_consent_{{ section.id }}';
  var banner = document.getElementById('AuraCookie-{{ section.id }}');
  var acceptBtn = document.getElementById('AuraCookieAccept-{{ section.id }}');
  var declineBtn = document.getElementById('AuraCookieDecline-{{ section.id }}');
  if (!banner) return;
  function setCookie(val) {
    try { localStorage.setItem(COOKIE_KEY, val); } catch(e){}
    banner.hidden = true;
  }
  try {
    if (!localStorage.getItem(COOKIE_KEY)) {
      setTimeout(function() { banner.hidden = false; }, 1000);
    }
  } catch(e) { banner.hidden = false; }
  if (acceptBtn) acceptBtn.addEventListener('click', function() { setCookie('accepted'); });
  if (declineBtn) declineBtn.addEventListener('click', function() { setCookie('declined'); });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Cookie Consent",
  "tag": "div",
  "class": "aura-cookie-section",
  "settings": [
    {"type":"checkbox","id":"enabled","label":"Ativar banner de cookies","default":true},
    {"type":"textarea","id":"message","label":"Mensagem","default":"Usamos cookies para melhorar sua experiência. Ao continuar navegando, você concorda com nossa"},
    {"type":"url","id":"policy_url","label":"Link da Política de Privacidade"},
    {"type":"text","id":"policy_label","label":"Texto do link","default":"Política de Privacidade"},
    {"type":"text","id":"accept_label","label":"Botão aceitar","default":"Aceitar"},
    {"type":"checkbox","id":"show_decline","label":"Exibir botão recusar","default":true},
    {"type":"text","id":"decline_label","label":"Botão recusar","default":"Recusar"}
  ],
  "presets": [{"name":"Cookie Consent"}]
}
{% endschema %}
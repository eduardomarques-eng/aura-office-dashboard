{% comment %}Aura Guia de Cuidados v1 — Como cuidar dos produtos — Sprint 11{% endcomment %}

<section class="aura-cuidado" id="AuraCuidado-{{ section.id }}">
  <div class="aura-cuidado__inner page-width">
    <div class="aura-cuidado__header">
      {%- if section.settings.kicker != blank -%}
        <span class="aura-cuidado__kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="aura-cuidado__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="aura-cuidado__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tip' -%}
        <div class="aura-cuidado__card" {{ block.shopify_attributes }}>
          <div class="aura-cuidado__icon" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'water' %}
              <svg viewBox="0 0 48 48" fill="none"><path d="M24 6C24 6 10 20 10 30a14 14 0 0028 0C38 20 24 6 24 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 32a6 6 0 006 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'sun' %}
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="8" stroke="currentColor" stroke-width="2"/><path d="M24 8v4M24 36v4M8 24h4M36 24h4M13 13l3 3M32 32l3 3M35 13l-3 3M16 32l-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'wind' %}
              <svg viewBox="0 0 48 48" fill="none"><path d="M8 18h22a6 6 0 000-12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M8 24h30a6 6 0 010 12H34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M8 30h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'temp' %}
              <svg viewBox="0 0 48 48" fill="none"><rect x="20" y="6" width="8" height="28" rx="4" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="36" r="6" stroke="currentColor" stroke-width="2"/><path d="M24 10v22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'soap' %}
              <svg viewBox="0 0 48 48" fill="none"><rect x="8" y="18" width="32" height="24" rx="2" stroke="currentColor" stroke-width="2"/><path d="M16 18v-6a8 8 0 0116 0v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M24 26v8M20 30h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'no-wash' %}
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2"/><path d="M12 12l24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M24 14C24 14 16 22 16 28a8 8 0 0016 0C32 22 24 14 24 14z" stroke="currentColor" stroke-width="2"/></svg>
              {% else %}
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2"/><path d="M24 18v6l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {% endcase %}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="aura-cuidado__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.desc != blank -%}
            <p class="aura-cuidado__card-desc">{{ block.settings.desc }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.aura-cuidado {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--aura-cream, #F2EDE6);
}
.aura-cuidado__header { text-align:center; margin-bottom:5.6rem; }
.aura-cuidado__kicker { display:block; font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase; color:var(--aura-terracota,#B8793A); margin-bottom:1.6rem; }
.aura-cuidado__heading { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:clamp(2.8rem,4vw,4rem); font-weight:400; font-style:italic; color:var(--aura-grafite,#3D3D3B); line-height:1.15; margin:0; }
.aura-cuidado__grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(18rem,1fr)); gap:3.2rem; }
@media(max-width:749px){ .aura-cuidado__grid { grid-template-columns:repeat(2,1fr); gap:2.4rem; } }
.aura-cuidado__card { display:flex; flex-direction:column; align-items:center; text-align:center; gap:1.6rem; }
.aura-cuidado__icon { width:4.8rem; height:4.8rem; color:var(--aura-terracota,#B8793A); }
.aura-cuidado__icon svg { width:100%; height:100%; }
.aura-cuidado__card-title { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:2rem; font-weight:400; color:var(--aura-grafite,#3D3D3B); margin:0; }
.aura-cuidado__card-desc { font-family:var(--font-body-family); font-size:1.3rem; font-weight:300; color:var(--aura-cinza,#7A7A78); line-height:1.7; margin:0; }
</style>

{% schema %}
{
  "name": "Guia de Cuidados",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {"type":"text","id":"kicker","label":"Kicker","default":"Como cuidar"},
    {"type":"text","id":"heading","label":"Título","default":"Cuidados para suas peças durarem para sempre"},
    {"type":"range","id":"padding_top","min":0,"max":120,"step":8,"unit":"px","label":"Espaço acima","default":96},
    {"type":"range","id":"padding_bottom","min":0,"max":120,"step":8,"unit":"px","label":"Espaço abaixo","default":96}
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Dica de Cuidado",
      "settings": [
        {"type":"select","id":"icon","label":"Ícone","options":[{"value":"water","label":"Agua"},{"value":"sun","label":"Sol"},{"value":"wind","label":"Vento"},{"value":"temp","label":"Temperatura"},{"value":"soap","label":"Sabao"},{"value":"no-wash","label":"Nao lavar"}],"default":"water"},
        {"type":"text","id":"title","label":"Título","default":"Limpeza suave"},
        {"type":"textarea","id":"desc","label":"Descrição","default":"Lave com agua morna e sabonete neutro. Nunca use detergente agressivo."}
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Guia de Cuidados",
      "blocks": [
        {"type":"tip","settings":{"icon":"soap","title":"Limpeza suave","desc":"Use pano levemente úmido e sabonete neutro. Evite produtos químicos agressivos."}},
        {"type":"tip","settings":{"icon":"sun","title":"Evite sol direto","desc":"A exposição prolongada ao sol pode desbotado as cores. Mantenha em ambientes com luz indireta."}},
        {"type":"tip","settings":{"icon":"water","title":"Secagem natural","desc":"Deixe secar naturalmente ao ar. A cerâmica porosa precisa secar completamente."}},
        {"type":"tip","settings":{"icon":"temp","title":"Temperatura ambiente","desc":"Evite choques térmicos bruscos. A cerâmica artesanal pode trincar com variações extremas."}},
        {"type":"tip","settings":{"icon":"wind","title":"Botânica seca","desc":"Sacuda suavemente com plumeiro ou jato de ar. Evite água — pois isso reverte a preservação."}},
        {"type":"tip","settings":{"icon":"no-wash","title":"Sem lava-louça","desc":"Peças artesanais não devem ir ao lava-louça. A temperatura alta e os detergentes danificam o esmalte."}}
      ]
    }
  ]
}
{% endschema %}
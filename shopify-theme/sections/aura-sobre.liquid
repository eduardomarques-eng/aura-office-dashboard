{% comment %}Aura Sobre v1 — Página Sobre Nós completa — Sprint 11{% endcomment %}

<article class="aura-sobre" id="AuraSobre-{{ section.id }}">

  <!-- Hero -->
  <div class="aura-sobre__hero">
    {%- if section.settings.hero_bg_url != blank -%}
      <img src="{{ section.settings.hero_bg_url }}" alt="Aura Decore — Nossa História" width="1920" height="1080" loading="eager" fetchpriority="high" class="aura-sobre__hero-img">
    {%- endif -%}
    <div class="aura-sobre__hero-overlay"></div>
    <div class="aura-sobre__hero-content">
      <span class="aura-sobre__hero-kicker">{{ section.settings.hero_kicker | default: 'Nossa História' }}</span>
      <h1 class="aura-sobre__hero-title">{{ section.settings.hero_heading | default: 'Nascemos de uma crença simples' }}</h1>
    </div>
  </div>

  <!-- Manifesto resumido -->
  <div class="aura-sobre__manifesto page-width">
    {%- if section.settings.manifesto_text != blank -%}
      <p class="aura-sobre__manifesto-text">{{ section.settings.manifesto_text }}</p>
    {%- endif -%}
  </div>

  <!-- Valores da marca -->
  {%- if section.blocks.size > 0 -%}
  <div class="aura-sobre__values">
    <div class="page-width">
      {%- if section.settings.values_heading != blank -%}
        <h2 class="aura-sobre__values-title">{{ section.settings.values_heading }}</h2>
      {%- endif -%}
      <div class="aura-sobre__values-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'value' -%}
          <div class="aura-sobre__value" {{ block.shopify_attributes }}>
            <span class="aura-sobre__value-num">0{{ forloop.index }}</span>
            <h3 class="aura-sobre__value-title">{{ block.settings.title }}</h3>
            <p class="aura-sobre__value-text">{{ block.settings.text }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Imagem diptych -->
  {%- if section.settings.img_left != blank or section.settings.img_left_url != blank or section.settings.img_right != blank or section.settings.img_right_url != blank -%}
  <div class="aura-sobre__diptych">
    <div class="aura-sobre__dip-left">
      {%- if section.settings.img_left != blank -%}
        <img src="{{ section.settings.img_left | image_url: width: 960 }}" alt="Aura Decore" width="960" height="1200" loading="lazy" class="aura-sobre__dip-img">
      {%- elsif section.settings.img_left_url != blank -%}
        <img src="{{ section.settings.img_left_url }}" alt="Aura Decore" width="960" height="1200" loading="lazy" class="aura-sobre__dip-img">
      {%- endif -%}
    </div>
    <div class="aura-sobre__dip-right">
      {%- if section.settings.img_right != blank -%}
        <img src="{{ section.settings.img_right | image_url: width: 960 }}" alt="Aura Decore" width="960" height="1200" loading="lazy" class="aura-sobre__dip-img">
      {%- elsif section.settings.img_right_url != blank -%}
        <img src="{{ section.settings.img_right_url }}" alt="Aura Decore" width="960" height="1200" loading="lazy" class="aura-sobre__dip-img">
      {%- endif -%}
      {%- if section.settings.dip_quote != blank -%}
      <div class="aura-sobre__dip-quote">
        <blockquote>{{ section.settings.dip_quote }}</blockquote>
      </div>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  <!-- CTA final -->
  {%- if section.settings.cta_label != blank -%}
  <div class="aura-sobre__cta-wrap page-width">
    <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="aura-sobre__cta">
      {{ section.settings.cta_label }}
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
  {%- endif -%}

</article>

<style>
.aura-sobre { background: var(--aura-off-white, #FAFAF8); }
/* Hero */
.aura-sobre__hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: var(--aura-linen, #EDE7DC);
}
.aura-sobre__hero-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 30%;
  display: block;
  animation: sobre-kb 20s ease-out forwards;
}
@keyframes sobre-kb { from { transform: scale(1); } to { transform: scale(1.06) translate(-1%, -1%); } }
.aura-sobre__hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(45,38,32,.7) 0%, transparent 55%),
    linear-gradient(to right, rgba(45,38,32,.4) 0%, transparent 50%);
}
.aura-sobre__hero-content {
  position: relative; z-index: 2;
  padding: 0 8% 7.2rem;
  max-width: 72rem;
}
.aura-sobre__hero-kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 400; letter-spacing: .28em; text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 2rem;
}
.aura-sobre__hero-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(3.6rem, 6vw, 7.2rem);
  font-weight: 300; line-height: .95; letter-spacing: -.02em;
  color: var(--aura-off-white, #FAFAF8);
  margin: 0;
}
/* Manifesto */
.aura-sobre__manifesto {
  padding: 9.6rem 0;
  text-align: center;
  max-width: 72rem;
  margin-left: auto; margin-right: auto;
}
.aura-sobre__manifesto-text {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2rem, 2.8vw, 2.8rem);
  font-weight: 300; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.55; margin: 0;
}
/* Valores */
.aura-sobre__values {
  background: var(--aura-cream, #F2EDE6);
  padding: 9.6rem 0;
}
.aura-sobre__values-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3vw, 3.2rem);
  font-weight: 400; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  text-align: center; margin: 0 0 5.6rem;
}
.aura-sobre__values-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(24rem, 1fr));
  gap: 4.8rem;
}
@media (max-width: 749px) { .aura-sobre__values-grid { grid-template-columns: 1fr; gap: 3.2rem; } }
.aura-sobre__value {
  border-top: 1px solid var(--aura-borda, #E2DBD4);
  padding-top: 2.4rem;
}
.aura-sobre__value-num {
  font-family: var(--font-heading-family);
  font-size: 3.6rem; font-weight: 300;
  color: var(--aura-terracota, #B8793A); opacity: .4;
  display: block; margin-bottom: 1.6rem; line-height: 1;
}
.aura-sobre__value-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: 2.2rem; font-weight: 400; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  margin: 0 0 1.2rem; line-height: 1.2;
}
.aura-sobre__value-text {
  font-family: var(--font-body-family);
  font-size: 1.4rem; font-weight: 300; line-height: 1.8;
  color: var(--aura-cinza, #7A7A78); margin: 0;
}
/* Diptych */
.aura-sobre__diptych {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 60rem;
}
@media (max-width: 749px) {
  .aura-sobre__diptych { grid-template-columns: 1fr; }
}
.aura-sobre__dip-left, .aura-sobre__dip-right {
  position: relative; overflow: hidden;
}
.aura-sobre__dip-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.aura-sobre__dip-right { background: var(--aura-linen, #EDE7DC); }
.aura-sobre__dip-quote {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  padding: 6.4rem;
}
.aura-sobre__dip-quote blockquote {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3.5vw, 3.6rem);
  font-weight: 300; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.35; text-align: center; margin: 0;
}
/* CTA */
.aura-sobre__cta-wrap { text-align: center; padding: 9.6rem 0; }
.aura-sobre__cta {
  display: inline-flex; align-items: center; gap: 1.2rem;
  background: var(--aura-grafite, #3D3D3B);
  color: var(--aura-off-white, #FAFAF8);
  border: 1.5px solid var(--aura-grafite, #3D3D3B);
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 400; letter-spacing: .18em; text-transform: uppercase;
  padding: 1.8rem 4.4rem; text-decoration: none;
  transition: background .35s ease, border-color .35s ease;
}
.aura-sobre__cta:hover { background: var(--aura-terracota, #B8793A); border-color: var(--aura-terracota, #B8793A); }
.aura-sobre__cta svg { transition: transform .3s ease; }
.aura-sobre__cta:hover svg { transform: translateX(5px); }
@media (prefers-reduced-motion: reduce) {
  .aura-sobre__hero-img { animation: none !important; }
  .aura-sobre__cta svg { transition: none !important; }
}
</style>

{% schema %}
{
  "name": "Sobre Nós",
  "tag": "section",
  "class": "spaced-section--full-width",
  "settings": [
    {"type":"header","content":"Hero"},
    {"type":"text","id":"hero_bg_url","label":"URL imagem hero"},
    {"type":"text","id":"hero_kicker","label":"Kicker","default":"Nossa História"},
    {"type":"text","id":"hero_heading","label":"Título hero","default":"Nascemos de uma crença simples"},
    {"type":"header","content":"Manifesto"},
    {"type":"textarea","id":"manifesto_text","label":"Texto do manifesto","default":"O ambiente em que você vive molda como você se sente. A Aura Decore nasceu para ajudar você a construir um lar que te acalma, te inspira e te lembra de quem você é."},
    {"type":"header","content":"Valores"},
    {"type":"text","id":"values_heading","label":"Título dos valores","default":"O que nos guia"},
    {"type":"header","content":"Imagens Diptych"},
    {"type":"image_picker","id":"img_left","label":"Imagem esquerda"},
    {"type":"text","id":"img_left_url","label":"URL imagem esquerda"},
    {"type":"image_picker","id":"img_right","label":"Imagem direita"},
    {"type":"text","id":"img_right_url","label":"URL imagem direita"},
    {"type":"textarea","id":"dip_quote","label":"Citação sobre imagem direita","default":"\"Sinta sua casa. Viva sua essência.\""},
    {"type":"header","content":"CTA"},
    {"type":"text","id":"cta_label","label":"Botão","default":"Explorar a Curadoria"},
    {"type":"url","id":"cta_link","label":"Link"}
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Valor da Marca",
      "settings": [
        {"type":"text","id":"title","label":"Título","default":"Intenção acima de tudo"},
        {"type":"textarea","id":"text","label":"Texto","default":"Cada peça é escolhida com propósito. Nunca quantidade, sempre qualidade."}
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Sobre Nós",
      "blocks": [
        {"type":"value","settings":{"title":"Intenção acima de tudo","text":"Cada peça é escolhida com propósito. Nunca quantidade, sempre significação."}},
        {"type":"value","settings":{"title":"Materiais que respeitam o tempo","text":"Bambu, linho, cerâmica, madeira. Materiais que envelhecem bonito."}},
        {"type":"value","settings":{"title":"Embalagem como ritual","text":"Cada entrega é um momento. Papel de seda, lacre de cera, cartão manuscrito."}},
        {"type":"value","settings":{"title":"Atendimento humano","text":"Respondemos a cada mensagem pessoalmente. Porque você merece mais do que um bot."}}
      ]
    }
  ]
}
{% endschema %}
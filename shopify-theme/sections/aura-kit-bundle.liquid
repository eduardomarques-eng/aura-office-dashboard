{% comment %}Aura Kit Bundle v1 — Monte seu Kit editorial — Sprint 11{% endcomment %}

<section class="aura-kit" id="AuraKit-{{ section.id }}">
  <div class="page-width">
    <div class="aura-kit__header">
      {%- if section.settings.kicker != blank -%}
        <span class="aura-kit__kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="aura-kit__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="aura-kit__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="aura-kit__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'kit' -%}
        <div class="aura-kit__card" {{ block.shopify_attributes }}>
          <div class="aura-kit__card-visual">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 720 }}" alt="{{ block.settings.title }}" width="720" height="540" loading="lazy" class="aura-kit__card-img">
            {%- elsif block.settings.image_url != blank -%}
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title }}" width="720" height="540" loading="lazy" class="aura-kit__card-img">
            {%- else -%}
              <div class="aura-kit__card-placeholder"></div>
            {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="aura-kit__card-badge">{{ block.settings.badge }}</span>
            {%- endif -%}
          </div>
          <div class="aura-kit__card-body">
            {%- if block.settings.kicker != blank -%}
              <span class="aura-kit__card-kicker">{{ block.settings.kicker }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="aura-kit__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.desc != blank -%}
              <p class="aura-kit__card-desc">{{ block.settings.desc }}</p>
            {%- endif -%}
            {%- if block.settings.price != blank -%}
              <div class="aura-kit__card-price">
                {%- if block.settings.price_original != blank -%}
                  <s class="aura-kit__card-price-original">{{ block.settings.price_original }}</s>
                {%- endif -%}
                <span class="aura-kit__card-price-val">{{ block.settings.price }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="aura-kit__card-cta">
                {{ block.settings.cta_label }}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.aura-kit {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--aura-linen, #EDE7DC);
}
.aura-kit__header {
  text-align: center;
  margin-bottom: 5.6rem;
}
.aura-kit__kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 400; letter-spacing: .22em; text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 1.6rem;
}
.aura-kit__heading {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.8rem, 4vw, 4.4rem);
  font-weight: 400; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.15; margin: 0 0 1.6rem;
}
.aura-kit__sub {
  font-family: var(--font-body-family);
  font-size: 1.5rem; font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.7; max-width: 56rem; margin: 0 auto;
}
.aura-kit__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(30rem, 1fr));
  gap: 2.4rem;
}
@media (max-width: 749px) { .aura-kit__grid { grid-template-columns: 1fr; } }
.aura-kit__card {
  background: var(--aura-off-white, #FAFAF8);
  display: flex; flex-direction: column;
  overflow: hidden;
  transition: box-shadow .35s ease;
}
.aura-kit__card:hover { box-shadow: 0 8px 32px rgba(61,61,59,.1); }
.aura-kit__card-visual {
  position: relative; overflow: hidden;
  aspect-ratio: 4/3;
}
.aura-kit__card-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform .6s cubic-bezier(.4,0,.2,1);
}
.aura-kit__card:hover .aura-kit__card-img { transform: scale(1.04); }
.aura-kit__card-placeholder {
  width: 100%; height: 100%;
  background: var(--aura-cream, #F2EDE6);
}
.aura-kit__card-badge {
  position: absolute; top: 1.6rem; left: 1.6rem;
  background: var(--aura-terracota, #B8793A);
  color: #fff;
  font-family: var(--font-body-family);
  font-size: 1rem; font-weight: 400; letter-spacing: .14em; text-transform: uppercase;
  padding: .4rem 1rem;
}
.aura-kit__card-body {
  padding: 2.8rem 3.2rem 3.2rem;
  display: flex; flex-direction: column; gap: 1.2rem; flex: 1;
}
.aura-kit__card-kicker {
  font-family: var(--font-body-family);
  font-size: 1rem; font-weight: 400; letter-spacing: .18em; text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
}
.aura-kit__card-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.2rem, 2.5vw, 2.8rem);
  font-weight: 400; font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.2; margin: 0;
}
.aura-kit__card-desc {
  font-family: var(--font-body-family);
  font-size: 1.4rem; font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.7; margin: 0;
}
.aura-kit__card-price {
  display: flex; align-items: center; gap: 1.2rem;
  margin-top: .4rem;
}
.aura-kit__card-price-original {
  font-family: var(--font-body-family);
  font-size: 1.3rem; font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  text-decoration: line-through;
}
.aura-kit__card-price-val {
  font-family: var(--font-body-family);
  font-size: 1.8rem; font-weight: 400;
  color: var(--aura-terracota, #B8793A);
}
.aura-kit__card-cta {
  display: inline-flex; align-items: center; gap: .8rem;
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 400; letter-spacing: .15em; text-transform: uppercase;
  color: var(--aura-grafite, #3D3D3B);
  text-decoration: none;
  border-bottom: 1px solid var(--aura-grafite, #3D3D3B);
  padding-bottom: .3rem;
  margin-top: auto; align-self: flex-start;
  transition: color .3s ease, border-color .3s ease;
}
.aura-kit__card-cta:hover { color: var(--aura-terracota, #B8793A); border-color: var(--aura-terracota, #B8793A); }
.aura-kit__card-cta svg { transition: transform .3s ease; }
.aura-kit__card-cta:hover svg { transform: translateX(4px); }
@media(prefers-reduced-motion:reduce){
  .aura-kit__card-img, .aura-kit__card-cta svg { transition:none!important; }
  .aura-kit__card:hover .aura-kit__card-img { transform: none; }
}
</style>


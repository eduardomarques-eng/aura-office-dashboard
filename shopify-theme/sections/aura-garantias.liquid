{% comment %}
  Aura Decore — Barra de Garantias/Benefícios
  Equivalente à seção de selos/garantias da Dcorada
{% endcomment %}

<style>
  .aura-garantias {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid rgba(26,26,26,0.06);
    border-bottom: 1px solid rgba(26,26,26,0.06);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .aura-garantias__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 5 }}, 1fr);
    gap: 24px;
    align-items: center;
  }
  .aura-garantia-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
  }
  .aura-garantia-item__icon {
    flex-shrink: 0;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    color: {{ section.settings.icon_color }};
  }
  .aura-garantia-item__icon svg { width: 32px; height: 32px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .aura-garantia-item__texto {}
  .aura-garantia-item__titulo {
    font-family: 'Inter', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    margin: 0 0 2px;
    display: block;
  }
  .aura-garantia-item__desc {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: {{ section.settings.text_color }};
    margin: 0;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }
  /* Divider entre itens */
  .aura-garantia-item:not(:last-child) {
    border-right: 1px solid rgba(26,26,26,0.07);
  }
  @media (max-width: 989px) {
    .aura-garantias__inner { grid-template-columns: repeat(2, 1fr); }
    .aura-garantia-item:not(:last-child) { border-right: none; border-bottom: 1px solid rgba(26,26,26,0.07); }
  }
  @media (max-width: 480px) {
    .aura-garantias__inner { grid-template-columns: 1fr; }
    .aura-garantia-item { padding: 10px 0; }
  }
</style>

<div class="aura-garantias">
  <div class="aura-garantias__inner">
    {% for block in section.blocks %}
      {% if block.type == 'beneficio' %}
      <div class="aura-garantia-item" {{ block.shopify_attributes }}>
        <div class="aura-garantia-item__icon">
          {% case block.settings.icone %}
            {% when 'frete' %}
            <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% when 'seguro' %}
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% when 'troca' %}
            <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg>
            {% when 'pagamento' %}
            <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            {% when 'qualidade' %}
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% when 'suporte' %}
            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          {% endcase %}
        </div>
        <div class="aura-garantia-item__texto">
          <span class="aura-garantia-item__titulo">{{ block.settings.titulo }}</span>
          <p class="aura-garantia-item__desc">{{ block.settings.descricao }}</p>
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Aura — Barra de Garantias",
  "blocks": [
    {
      "type": "beneficio",
      "name": "Benefício",
      "settings": [
        {
          "type": "select",
          "id": "icone",
          "label": "Ícone",
          "options": [
            { "value": "frete",     "label": "Frete / Entrega" },
            { "value": "seguro",    "label": "Segurança / Escudo" },
            { "value": "troca",     "label": "Troca / Devolução" },
            { "value": "pagamento", "label": "Pagamento / Cartão" },
            { "value": "qualidade", "label": "Qualidade / Estrela" },
            { "value": "suporte",   "label": "Suporte / Chat" }
          ],
          "default": "frete"
        },
        {
          "type": "text",
          "id": "titulo",
          "label": "Título",
          "default": "Frete Grátis"
        },
        {
          "type": "text",
          "id": "descricao",
          "label": "Descrição",
          "default": "Nas compras acima de R$ 299"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Cor dos ícones",
      "default": "#B8976A"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor dos títulos",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor das descrições",
      "default": "#8A8680"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 12,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Espaço superior",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 12,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Espaço inferior",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Aura — Barra de Garantias",
      "blocks": [
        { "type": "beneficio", "settings": { "icone": "frete",     "titulo": "Frete Grátis",      "descricao": "Nas compras acima de R$ 299" } },
        { "type": "beneficio", "settings": { "icone": "seguro",    "titulo": "Compra Segura",     "descricao": "Ambiente 100% criptografado" } },
        { "type": "beneficio", "settings": { "icone": "troca",     "titulo": "Troca Facilitada",  "descricao": "Até 30 dias após a entrega" } },
        { "type": "beneficio", "settings": { "icone": "pagamento", "titulo": "10% no Pix",        "descricao": "Desconto no pagamento via Pix" } }
      ]
    }
  ]
}
{% endschema %}

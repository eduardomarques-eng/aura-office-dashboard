{% comment %}Aura Editorial Split v1 — 50/50 imagem + copy premium — Sprint 11{% endcomment %}

<section class="aura-split" id="AuraSplit-{{ section.id }}">
  <div class="aura-split__grid{% if section.settings.reverse %} aura-split__grid--reverse{% endif %}">
    <div class="aura-split__visual">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w" sizes="(max-width:749px) 100vw, 50vw" alt="{{ section.settings.image.alt | default: section.settings.heading }}" width="1200" height="900" loading="lazy" class="aura-split__img">
      {%- elsif section.settings.image_url != blank -%}
        <img src="{{ section.settings.image_url }}" alt="{{ section.settings.heading | default: 'Aura Decore' }}" width="1200" height="900" loading="lazy" class="aura-split__img">
      {%- else -%}
        <div class="aura-split__placeholder"></div>
      {%- endif -%}
      {%- if section.settings.stat_number != blank -%}
      <div class="aura-split__stat">
        <span class="aura-split__stat-num">{{ section.settings.stat_number }}</span>
        <span class="aura-split__stat-label">{{ section.settings.stat_label }}</span>
      </div>
      {%- endif -%}
    </div>
    <div class="aura-split__content">
      {%- if section.settings.kicker != blank -%}
        <span class="aura-split__kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="aura-split__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="aura-split__body">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.features != blank -%}
      <ul class="aura-split__features">
        {%- assign feats = section.settings.features | split: '|' -%}
        {%- for feat in feats -%}
          {%- if feat != blank -%}<li>{{ feat | strip }}</li>{%- endif -%}
        {%- endfor -%}
      </ul>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="aura-split__cta">
          {{ section.settings.cta_label }}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.aura-split { background: {{ section.settings.bg_color | default: '#FAFAF8' }}; }
.aura-split__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 56rem;
}
.aura-split__grid--reverse { direction: rtl; }
.aura-split__grid--reverse > * { direction: ltr; }
@media (max-width: 849px) {
  .aura-split__grid { grid-template-columns: 1fr; min-height: auto; }
  .aura-split__grid--reverse { direction: ltr; }
}
.aura-split__visual { position: relative; overflow: hidden; min-height: 40rem; }
.aura-split__img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
  transition: transform .7s cubic-bezier(.4,0,.2,1);
}
.aura-split:hover .aura-split__img { transform: scale(1.03); }
.aura-split__placeholder { position:absolute; inset:0; background:var(--aura-linen,#EDE7DC); }
.aura-split__stat {
  position: absolute;
  bottom: 3.2rem; left: 3.2rem;
  background: rgba(45,38,32,.75);
  backdrop-filter: blur(8px);
  padding: 1.6rem 2.4rem;
  display: flex; flex-direction: column; gap: .4rem;
}
.aura-split__stat-num {
  font-family: var(--font-heading-family,'Cormorant Garamond',serif);
  font-size: 4rem; font-weight: 300; color: #fff; line-height: 1;
}
.aura-split__stat-label {
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 300; letter-spacing: .14em; text-transform: uppercase;
  color: rgba(250,250,248,.7);
}
.aura-split__content {
  display: flex; flex-direction: column; justify-content: center;
  padding: 6.4rem 8rem;
  gap: 2rem;
}
@media (max-width: 1199px) { .aura-split__content { padding: 4.8rem; } }
@media (max-width: 749px) { .aura-split__content { padding: 4rem 2.4rem; } }
.aura-split__kicker { font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase; color:var(--aura-terracota,#B8793A); }
.aura-split__heading { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:clamp(2.8rem,3.5vw,4.8rem); font-weight:400; font-style:italic; color:var(--aura-grafite,#3D3D3B); line-height:1.1; margin:0; }
.aura-split__body { font-family:var(--font-body-family); font-size:1.5rem; font-weight:300; color:var(--aura-cinza,#7A7A78); line-height:1.8; }
.aura-split__body p { margin:0; }
.aura-split__features { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:.8rem; border-top:1px solid var(--aura-borda,#E2DBD4); padding-top:2rem; }
.aura-split__features li { font-family:var(--font-body-family); font-size:1.35rem; font-weight:300; color:var(--aura-grafite,#3D3D3B); padding-left:2rem; position:relative; }
.aura-split__features li::before { content:'\2014'; position:absolute; left:0; color:var(--aura-terracota,#B8793A); }
.aura-split__cta { display:inline-flex; align-items:center; gap:1.2rem; background:var(--aura-grafite,#3D3D3B); color:var(--aura-off-white,#FAFAF8); border:1.5px solid var(--aura-grafite,#3D3D3B); font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.18em; text-transform:uppercase; padding:1.7rem 3.8rem; text-decoration:none; align-self:flex-start; transition:background .35s ease,border-color .35s ease; margin-top:.4rem; }
.aura-split__cta:hover { background:var(--aura-terracota,#B8793A); border-color:var(--aura-terracota,#B8793A); }
.aura-split__cta svg { transition:transform .3s ease; }
.aura-split__cta:hover svg { transform:translateX(5px); }
@media(prefers-reduced-motion:reduce){
  .aura-split__img,.aura-split__cta svg { transition:none!important; }
  .aura-split:hover .aura-split__img { transform:none; }
}
</style>

{% schema %}
{
  "name": "Editorial Split 50/50",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {"type":"header","content":"Imagem"},
    {"type":"image_picker","id":"image","label":"Imagem"},
    {"type":"text","id":"image_url","label":"URL da imagem (CDN)"},
    {"type":"text","id":"stat_number","label":"Estatística (numéro)","default":"500+"},
    {"type":"text","id":"stat_label","label":"Estatística (label)","default":"peças curadas"},
    {"type":"header","content":"Conteúdo"},
    {"type":"text","id":"kicker","label":"Kicker","default":"Nossa curadoria"},
    {"type":"text","id":"heading","label":"Título","default":"Peças com história e propósito"},
    {"type":"richtext","id":"body","label":"Corpo do texto","default":"<p>Cada peça da Aura Decore é selecionada com cuidado. Não é sobre quantidade — é sobre significação.<\/p>"},
    {"type":"textarea","id":"features","label":"Features (separar por |)","default":"Materiais nobres e naturais | Artesanato autentico | Durabilidade garantida"},
    {"type":"text","id":"cta_label","label":"Botão","default":"Explorar a curadoria"},
    {"type":"url","id":"cta_link","label":"Link do botão"},
    {"type":"header","content":"Layout"},
    {"type":"checkbox","id":"reverse","label":"Inverter (imagem à direita)","default":false},
    {"type":"text","id":"bg_color","label":"Cor de fundo (hex)","default":"#FAFAF8"}
  ],
  "presets": [
    {
      "name": "Editorial Split 50/50",
      "settings": {
        "kicker": "Nossa curadoria",
        "heading": "Peças com história e propósito",
        "stat_number": "500+",
        "stat_label": "peças curadas",
        "cta_label": "Explorar a curadoria",
        "image_url": "https://image.pollinations.ai/prompt/japandi%20ceramic%20vase%20collection%20artisan%20hands%20crafting%20warm%20studio%20light%20editorial?width=1200&height=900&model=flux-realism&seed=8001&nologo=true"
      }
    }
  ]
}
{% endschema %}
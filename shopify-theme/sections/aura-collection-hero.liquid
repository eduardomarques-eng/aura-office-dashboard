{% comment %}Aura Collection Hero v1 — Banner de coleção com imagem + copy — Sprint 11{% endcomment %}

{%- liquid
  assign col = section.settings.collection
  assign col_image = section.settings.collection_image
  assign col_bg_url = section.settings.bg_url
  if col != blank and col_image == blank and col_bg_url == blank
    if col.image != blank
      assign col_image = col.image
    endif
  endif
-%}

<div class="aura-col-hero" id="AuraColHero-{{ section.id }}">
  {%- if col_image != blank or col_bg_url != blank -%}
  <div class="aura-col-hero__media">
    {%- if col_image != blank -%}
      <img src="{{ col_image | image_url: width: 1920 }}" srcset="{{ col_image | image_url: width: 750 }} 750w, {{ col_image | image_url: width: 1200 }} 1200w, {{ col_image | image_url: width: 1920 }} 1920w" sizes="100vw" alt="{{ col_image.alt | default: col.title }}" width="1920" height="540" loading="eager" fetchpriority="high" class="aura-col-hero__img">
    {%- elsif col_bg_url != blank -%}
      <img src="{{ col_bg_url }}" alt="{{ col.title | default: section.settings.heading }}" width="1920" height="540" loading="eager" fetchpriority="high" class="aura-col-hero__img">
    {%- endif -%}
    <div class="aura-col-hero__overlay"></div>
  </div>
  {%- else -%}
  <div class="aura-col-hero__fallback"></div>
  {%- endif -%}

  <div class="aura-col-hero__content page-width">
    {%- assign heading = section.settings.heading -%}
    {%- if heading == blank and col != blank -%}{%- assign heading = col.title -%}{%- endif -%}
    {%- assign desc = section.settings.description -%}
    {%- if desc == blank and col != blank and col.description != blank -%}{%- assign desc = col.description -%}{%- endif -%}
    {%- if section.settings.kicker != blank -%}
      <span class="aura-col-hero__kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if heading != blank -%}
      <h1 class="aura-col-hero__title">{{ heading }}</h1>
    {%- endif -%}
    {%- if desc != blank -%}
      <p class="aura-col-hero__desc">{{ desc | strip_html | truncate: 200 }}</p>
    {%- endif -%}
  </div>
</div>

<style>
.aura-col-hero {
  position: relative;
  min-height: {{ section.settings.height_desktop }}vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: var(--aura-linen, #EDE7DC);
}
@media (max-width: 749px) { .aura-col-hero { min-height: {{ section.settings.height_mobile }}vh; } }
.aura-col-hero__media { position: absolute; inset: 0; overflow: hidden; }
.aura-col-hero__img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}
.aura-col-hero__fallback {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--aura-linen) 0%, var(--aura-beige, #F5F0EB) 100%);
}
.aura-col-hero__overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(45,38,32,.65) 0%, transparent 55%),
    linear-gradient(to right, rgba(45,38,32,.2) 0%, transparent 50%);
}
.aura-col-hero__content {
  position: relative; z-index: 2;
  padding: 0 0 4.8rem;
}
.aura-col-hero__kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem; font-weight: 400; letter-spacing: .22em; text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 1.2rem;
}
.aura-col-hero__title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(3.2rem, 5vw, 6.4rem);
  font-weight: 300; line-height: 1; letter-spacing: -.01em;
  color: var(--aura-off-white, #FAFAF8);
  margin: 0 0 1.6rem;
}
.aura-col-hero__desc {
  font-family: var(--font-body-family);
  font-size: 1.4rem; font-weight: 300; line-height: 1.7;
  color: rgba(250,250,248,.8);
  max-width: 52rem; margin: 0;
}
@media(prefers-reduced-motion:reduce){ .aura-col-hero__img { animation:none!important; } }
</style>

{% schema %}
{
  "name": "Hero Coleção",
  "tag": "div",
  "class": "aura-collection-hero",
  "settings": [
    {"type":"collection","id":"collection","label":"Coleção"},
    {"type":"image_picker","id":"collection_image","label":"Imagem personalizada"},
    {"type":"text","id":"bg_url","label":"URL da imagem (CDN)"},
    {"type":"text","id":"kicker","label":"Kicker"},
    {"type":"text","id":"heading","label":"Título (substitui nome da coleção)"},
    {"type":"textarea","id":"description","label":"Descrição (substitui descrição da coleção)"},
    {"type":"range","id":"height_desktop","min":20,"max":60,"step":5,"unit":"vh","label":"Altura desktop","default":40},
    {"type":"range","id":"height_mobile","min":20,"max":50,"step":5,"unit":"vh","label":"Altura mobile","default":30}
  ],
  "presets": [{"name":"Hero Coleção"}]
}
{% endschema %}
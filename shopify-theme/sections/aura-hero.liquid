{% comment %}Aura Hero v5 — Ken Burns + triplo CTA (primary/secondary/ghost) + shimmer — Sprint 9{% endcomment %}
{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  elsif section.settings.bg_url != blank
    assign has_image = true
  endif
-%}

<section class="aura-hero{% if section.settings.overlay_enabled %} aura-hero--overlay{% endif %}" id="AuraHero-{{ section.id }}">

  {%- if has_image -%}
  <div class="aura-hero__media aura-parallax-container">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1920 }}" srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1500 }} 1500w, {{ section.settings.image | image_url: width: 1920 }} 1920w" sizes="100vw" alt="{{ section.settings.image.alt | default: 'Aura Decore' }}" width="1920" height="1080" loading="eager" fetchpriority="high" class="aura-parallax-img aura-hero__bg-img">
    {%- elsif section.settings.bg_url != blank -%}
      {%- assign bg_src = section.settings.bg_url -%}
      {%- if section.settings.bg_url contains '.png' or section.settings.bg_url contains '.jpg' or section.settings.bg_url contains '.jpeg' -%}
        {%- unless section.settings.bg_url contains 'http://' or section.settings.bg_url contains 'https://' -%}
          {%- assign bg_src = section.settings.bg_url | asset_url -%}
        {%- endunless -%}
      {%- endif -%}
      <img src="{{ bg_src }}" alt="Aura Decore — Curadoria Japandi & Minimalismo" width="1920" height="1080" loading="eager" fetchpriority="high" class="aura-parallax-img aura-hero__bg-img">
    {%- endif -%}
    <div class="aura-hero__overlay"></div>
  </div>
  {%- else -%}
  <div class="aura-hero__media" style="background:linear-gradient(135deg,var(--aura-linen,#F5F0EB) 0%,var(--aura-beige,#F2EDE6) 50%,var(--aura-cream,#EDE8E0) 100%);"></div>
  {%- endif -%}

  <div class="aura-hero__content" data-aura-reveal>
    {%- if section.settings.badge != blank -%}
      <div class="aura-hero__badge">{{ section.settings.badge }}</div>
    {%- endif -%}
    {%- if section.settings.kicker != blank -%}
      <span class="aura-hero__kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="aura-hero__title">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="aura-hero__desc">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="aura-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="aura-hero__btn-primary">
          <span class="aura-hero__btn-text">{{ section.settings.button_label }}</span>
          <span class="aura-hero__btn-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_link | default: '/collections/all' }}" class="aura-hero__btn-secondary">
          <span class="aura-hero__btn-text">{{ section.settings.button2_label }}</span>
          <span class="aura-hero__btn-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      {%- endif -%}
      {%- if section.settings.button3_label != blank -%}
        <a href="{{ section.settings.button3_link | default: '/pages/sobre' }}" class="aura-hero__btn-ghost">{{ section.settings.button3_label }} <span class="aura-hero__btn-arrow" aria-hidden="true">&#8594;</span></a>
      {%- endif -%}
    </div>
    {%- if section.settings.trust_1 != blank -%}
    <div class="aura-hero__trust">
      {%- if section.settings.trust_1 != blank -%}<span class="aura-hero__trust-item">{{ section.settings.trust_1 }}</span>{%- endif -%}
      {%- if section.settings.trust_2 != blank -%}<span class="aura-hero__trust-sep">&#183;</span><span class="aura-hero__trust-item">{{ section.settings.trust_2 }}</span>{%- endif -%}
      {%- if section.settings.trust_3 != blank -%}<span class="aura-hero__trust-sep">&#183;</span><span class="aura-hero__trust-item">{{ section.settings.trust_3 }}</span>{%- endif -%}
    </div>
    {%- endif -%}
  </div>

  {%- if section.settings.scroll_hint -%}
  <div class="aura-hero__scroll" aria-hidden="true">
    <span class="aura-hero__scroll-line"></span>
    <span class="aura-hero__scroll-text">scroll</span>
  </div>
  {%- endif -%}

</section>

<style>
#AuraHero-{{ section.id }} { min-height:{{ section.settings.height_desktop }}vh; }
@media(max-width:749px){ #AuraHero-{{ section.id }}{ min-height:{{ section.settings.height_mobile }}vh; } }

/* Ken Burns — animação cinemática */
@keyframes aura-ken-burns { 0%{ transform:scale(1) translate(0,0); } 100%{ transform:scale(1.07) translate(-1%,-1%); } }
.aura-hero__bg-img { width:100%;height:100%;object-fit:cover;object-position:center 20%;animation:aura-ken-burns 22s ease-out forwards; }

/* Overlay direcional */
.aura-hero__overlay {
  position:absolute;inset:0;
  background:
    linear-gradient(to right,rgba(245,240,235,.88) 0%,rgba(245,240,235,.55) 38%,rgba(245,240,235,.08) 65%,transparent 80%),
    linear-gradient(to top,rgba(45,38,32,.42) 0%,transparent 38%);
}

/* Badge */
.aura-hero__badge {
  display:inline-block;
  font-family:var(--font-body-family);font-size:1rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;
  color:var(--aura-terracota,#B8793A);
  border:1px solid var(--aura-terracota,#B8793A);
  padding:.5rem 1.4rem;
  margin-bottom:2rem;
}

/* Hero actions */
.aura-hero__actions { display:flex;align-items:center;flex-wrap:wrap;gap:2.4rem;margin-top:.4rem; }

/* Botão primário — grafite escuro + shimmer + seta */
.aura-hero__btn-primary {
  background:var(--aura-grafite,#3D3D3B);
  color:var(--aura-off-white,#FAFAF8);
  border:1.5px solid var(--aura-grafite,#3D3D3B);
  font-family:var(--font-body-family);font-size:1.1rem;font-weight:400;
  letter-spacing:.18em;text-transform:uppercase;
  padding:1.8rem 4.4rem;
  text-decoration:none;
  display:inline-flex;align-items:center;gap:1.2rem;
  position:relative;overflow:hidden;
  transition:background .35s ease,border-color .35s ease;
}
.aura-hero__btn-primary:hover {
  background:var(--aura-terracota,#B8793A);
  border-color:var(--aura-terracota,#B8793A);
}

/* Shimmer sweep */
@keyframes aura-hero-shimmer { 0%{left:-60%} 50%,100%{left:150%} }
.aura-hero__btn-primary::before {
  content:'';
  position:absolute;top:0;left:-60%;width:50%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.22),transparent);
  transform:skewX(-15deg);
  animation:aura-hero-shimmer 3.5s ease-in-out infinite 1.8s;
}

/* Seta animada — compartilhada primary/secondary */
.aura-hero__btn-icon {
  display:flex;align-items:center;
  transition:transform .35s cubic-bezier(.4,0,.2,1);
  flex-shrink:0;
}
.aura-hero__btn-primary:hover .aura-hero__btn-icon,
.aura-hero__btn-secondary:hover .aura-hero__btn-icon { transform:translateX(5px); }

/* Botão secundário — outline terracota (Ver Produtos / Minimalismo) */
.aura-hero__btn-secondary {
  background:transparent;
  color:var(--aura-terracota,#B8793A);
  border:1.5px solid var(--aura-terracota,#B8793A);
  font-family:var(--font-body-family);font-size:1.1rem;font-weight:400;
  letter-spacing:.18em;text-transform:uppercase;
  padding:1.8rem 4rem;
  text-decoration:none;
  display:inline-flex;align-items:center;gap:1.2rem;
  transition:background .35s ease,color .35s ease,border-color .35s ease;
}
.aura-hero__btn-secondary:hover {
  background:var(--aura-terracota,#B8793A);
  color:var(--aura-off-white,#FAFAF8);
}

/* Ghost button */
.aura-hero__btn-ghost {
  font-family:var(--font-body-family);font-size:1.1rem;font-weight:400;letter-spacing:.12em;
  color:var(--aura-grafite,#3D3D3B);text-decoration:none;
  display:inline-flex;align-items:center;gap:.8rem;
  border-bottom:1px solid transparent;
  transition:border-color .3s ease,color .3s ease;
  padding-bottom:.2rem;
}
.aura-hero__btn-ghost:hover { border-bottom-color:var(--aura-terracota,#B8793A);color:var(--aura-terracota,#B8793A); }
.aura-hero__btn-arrow { transition:transform .3s ease; display:inline-block; }
.aura-hero__btn-ghost:hover .aura-hero__btn-arrow { transform:translateX(4px); }

/* Trust badges */
.aura-hero__trust { display:flex;align-items:center;flex-wrap:wrap;gap:.8rem;margin-top:4rem; }
.aura-hero__trust-item { font-family:var(--font-body-family);font-size:1.1rem;font-weight:300;letter-spacing:.08em;color:var(--aura-cinza,#7A7A78); }
.aura-hero__trust-sep { color:var(--aura-borda,#D4CBC0);font-size:1.4rem; }

/* Scroll hint */
.aura-hero__scroll { position:absolute;bottom:3.2rem;right:5.6rem;display:flex;flex-direction:column;align-items:center;gap:.8rem;z-index:3; }
@media(max-width:749px){ .aura-hero__scroll{ display:none; } }
.aura-hero__scroll-line { width:1px;height:4.8rem;background:var(--aura-grafite,#3D3D3B);opacity:.45;display:block;animation:scrollPulse 2.4s ease-in-out infinite; }
.aura-hero__scroll-text { font-family:var(--font-body-family);font-size:.9rem;letter-spacing:.24em;text-transform:uppercase;color:var(--aura-cinza,#7A7A78);writing-mode:vertical-rl;opacity:.6; }
@keyframes scrollPulse { 0%,100%{ opacity:.45;transform:scaleY(1) translateY(0); } 60%{ opacity:.15;transform:scaleY(.6) translateY(6px); } }

/* Reduced motion */
@media(prefers-reduced-motion:reduce){
  .aura-hero__bg-img { animation:none!important; }
  .aura-hero__btn-primary::before { animation:none!important; }
  .aura-hero__btn-icon { transition:none!important; }
  .aura-hero__btn-arrow { transition:none!important; }
}
</style>

{% schema %}
{"name":"Aura Hero","tag":"section","class":"spaced-section","settings":[{"type":"header","content":"Imagem de Fundo"},{"type":"image_picker","id":"image","label":"Imagem upload Shopify"},{"type":"text","id":"bg_url","label":"URL da imagem CDN"},{"type":"range","id":"height_desktop","min":50,"max":100,"step":5,"unit":"vh","label":"Altura desktop","default":90},{"type":"range","id":"height_mobile","min":50,"max":100,"step":5,"unit":"vh","label":"Altura mobile","default":75},{"type":"checkbox","id":"overlay_enabled","label":"Ativar overlay","default":true},{"type":"header","content":"Conteudo"},{"type":"text","id":"badge","label":"Badge"},{"type":"text","id":"kicker","label":"Kicker","default":"Curadoria Japandi"},{"type":"richtext","id":"heading","label":"Titulo","default":"<p>O espaco que <em>respira.<\/em><\/p>"},{"type":"text","id":"subheading","label":"Descricao","default":"Pecas selecionadas para habitar com intencao."},{"type":"header","content":"Botoes"},{"type":"text","id":"button_label","label":"Botao primario grafite","default":"Ir a Colecao"},{"type":"url","id":"button_link","label":"Link botao primario"},{"type":"text","id":"button2_label","label":"Botao secundario terracota"},{"type":"url","id":"button2_link","label":"Link botao secundario"},{"type":"text","id":"button3_label","label":"Botao ghost texto"},{"type":"url","id":"button3_link","label":"Link botao ghost"},{"type":"header","content":"Trust Badges"},{"type":"text","id":"trust_1","label":"Badge 1","default":"Frete gratis acima de R$ 299"},{"type":"text","id":"trust_2","label":"Badge 2","default":"Troca gratis em 30 dias"},{"type":"text","id":"trust_3","label":"Badge 3","default":"Embalagem presente"},{"type":"checkbox","id":"scroll_hint","label":"Scroll hint","default":true}],"presets":[{"name":"Aura Hero"}]}
{% endschema %}
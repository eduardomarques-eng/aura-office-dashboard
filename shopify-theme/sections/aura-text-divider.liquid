{% comment %}
  Aura Decore — Divisor Editorial de Texto
  Linha fina com frase serif centralizada
  Sprint 3
{% endcomment %}

<div class="aura-divider" id="AuraDivider-{{ section.id }}" data-aura-reveal>
  <span class="aura-divider__line"></span>
  <span class="aura-divider__text">
    {%- if section.settings.text != blank -%}
      {{ section.settings.text }}
    {%- else -%}
      <em>objeto com alma</em>
    {%- endif -%}
  </span>
  <span class="aura-divider__line"></span>
</div>

<style>
  #AuraDivider-{{ section.id }} { padding: var(--s-64) var(--s-96); }
  @media (max-width: 749px) {
    #AuraDivider-{{ section.id }} { padding: var(--s-48) var(--s-24); }
  }
</style>

{% schema %}
{
  "name": "Aura Divisor de Texto",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Frase",
      "default": "objeto com alma"
    }
  ],
  "presets": [
    { "name": "Aura Divisor", "settings": { "text": "objeto com alma" } }
  ]
}
{% endschema %}

{% comment %}Aura Gift Guide v1 — Guia de presentes por ocasiao — Sprint 11{% endcomment %}

<section class="aura-gift" id="AuraGift-{{ section.id }}">
  <div class="aura-gift__header page-width">
    {%- if section.settings.kicker != blank -%}
      <span class="aura-gift__kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="aura-gift__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="aura-gift__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="aura-gift__tabs page-width">
    {%- for block in section.blocks -%}
      {%- if block.type == 'occasion' -%}
      <button
        class="aura-gift__tab{% if forloop.first %} is-active{% endif %}"
        data-gift-tab="{{ section.id }}-{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {{ block.settings.occasion_label }}
      </button>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- for block in section.blocks -%}
    {%- if block.type == 'occasion' -%}
    <div
      class="aura-gift__panel{% if forloop.first %} is-active{% endif %}"
      id="aura-gift-panel-{{ section.id }}-{{ forloop.index0 }}"
      data-gift-panel="{{ section.id }}-{{ forloop.index0 }}"
      {{ block.shopify_attributes }}
    >
      <div class="aura-gift__panel-inner page-width">
        {%- if block.settings.occasion_desc != blank -%}
          <p class="aura-gift__panel-desc">{{ block.settings.occasion_desc }}</p>
        {%- endif -%}
        <div class="aura-gift__panel-items">
          {%- for i in (1..4) -%}
            {%- liquid
              assign item_title = 'item_' | append: i | append: '_title'
              assign item_price = 'item_' | append: i | append: '_price'
              assign item_link = 'item_' | append: i | append: '_link'
              assign item_badge = 'item_' | append: i | append: '_badge'
            -%}
            {%- if block.settings[item_title] != blank -%}
            <a href="{{ block.settings[item_link] | default: '/collections/all' }}" class="aura-gift__item">
              {%- if block.settings[item_badge] != blank -%}
                <span class="aura-gift__item-badge">{{ block.settings[item_badge] }}</span>
              {%- endif -%}
              <span class="aura-gift__item-title">{{ block.settings[item_title] }}</span>
              {%- if block.settings[item_price] != blank -%}
                <span class="aura-gift__item-price">{{ block.settings[item_price] }}</span>
              {%- endif -%}
              <svg class="aura-gift__item-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if block.settings.cta_label != blank -%}
        <div class="aura-gift__panel-cta">
          <a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="aura-gift__cta-btn">
            {{ block.settings.cta_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        {%- endif -%}
      </div>
    </div>
    {%- endif -%}
  {%- endfor -%}
</section>

<style>
.aura-gift {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--aura-cream, #F2EDE6);
}
.aura-gift__header { text-align: center; margin-bottom: 4.8rem; }
.aura-gift__kicker { display:block; font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase; color:var(--aura-terracota,#B8793A); margin-bottom:1.6rem; }
.aura-gift__heading { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:clamp(2.8rem,4vw,4.4rem); font-weight:400; font-style:italic; color:var(--aura-grafite,#3D3D3B); line-height:1.15; margin:0 0 1.6rem; }
.aura-gift__sub { font-family:var(--font-body-family); font-size:1.5rem; font-weight:300; color:var(--aura-cinza,#7A7A78); line-height:1.7; max-width:56rem; margin:0 auto; }
/* Tabs */
.aura-gift__tabs { display:flex; gap:0; border-bottom:1px solid var(--aura-borda,#E2DBD4); margin-bottom:4rem; flex-wrap:wrap; }
.aura-gift__tab { background:none; border:none; border-bottom:2px solid transparent; margin-bottom:-1px; padding:1.4rem 2.4rem; font-family:var(--font-body-family); font-size:1.2rem; font-weight:400; letter-spacing:.12em; text-transform:uppercase; color:var(--aura-cinza,#7A7A78); cursor:pointer; transition:color .25s ease,border-color .25s ease; }
.aura-gift__tab.is-active,.aura-gift__tab:hover { color:var(--aura-terracota,#B8793A); border-bottom-color:var(--aura-terracota,#B8793A); }
/* Panels */
.aura-gift__panel { display:none; }
.aura-gift__panel.is-active { display:block; }
.aura-gift__panel-desc { font-family:var(--font-heading-family); font-size:1.8rem; font-weight:300; font-style:italic; color:var(--aura-grafite,#3D3D3B); margin:0 0 3.2rem; max-width:56rem; }
.aura-gift__panel-items { display:grid; grid-template-columns:repeat(auto-fit,minmax(22rem,1fr)); gap:1.2rem; }
.aura-gift__item { display:flex; align-items:center; gap:1.2rem; padding:1.8rem 2.4rem; background:var(--aura-off-white,#FAFAF8); text-decoration:none; border-left:3px solid transparent; transition:border-color .25s ease,background .25s ease; position:relative; }
.aura-gift__item:hover { border-left-color:var(--aura-terracota,#B8793A); background:var(--aura-linen,#EDE7DC); }
.aura-gift__item-badge { position:absolute; top:.8rem; right:.8rem; background:var(--aura-terracota,#B8793A); color:#fff; font-family:var(--font-body-family); font-size:.95rem; font-weight:400; letter-spacing:.1em; text-transform:uppercase; padding:.2rem .7rem; }
.aura-gift__item-title { font-family:var(--font-body-family); font-size:1.4rem; font-weight:400; color:var(--aura-grafite,#3D3D3B); flex:1; }
.aura-gift__item-price { font-family:var(--font-body-family); font-size:1.3rem; font-weight:300; color:var(--aura-cinza,#7A7A78); flex-shrink:0; }
.aura-gift__item-arrow { color:var(--aura-terracota,#B8793A); flex-shrink:0; transition:transform .25s ease; }
.aura-gift__item:hover .aura-gift__item-arrow { transform:translateX(4px); }
.aura-gift__panel-cta { text-align:center; margin-top:4rem; }
.aura-gift__cta-btn { display:inline-flex; align-items:center; gap:1rem; background:var(--aura-grafite,#3D3D3B); color:var(--aura-off-white,#FAFAF8); border:1.5px solid var(--aura-grafite,#3D3D3B); font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.18em; text-transform:uppercase; padding:1.6rem 3.6rem; text-decoration:none; transition:background .3s ease,border-color .3s ease; }
.aura-gift__cta-btn:hover { background:var(--aura-terracota,#B8793A); border-color:var(--aura-terracota,#B8793A); }
@media(prefers-reduced-motion:reduce){ .aura-gift__item-arrow,.aura-gift__cta-btn { transition:none!important; } }
</style>

<script>
(function(){
  var gift = document.getElementById('AuraGift-{{ section.id }}');
  if (!gift) return;
  var tabs = gift.querySelectorAll('.aura-gift__tab');
  var panels = gift.querySelectorAll('.aura-gift__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var key = this.dataset.giftTab;
      tabs.forEach(function(t){ t.classList.remove('is-active'); });
      panels.forEach(function(p){ p.classList.remove('is-active'); });
      this.classList.add('is-active');
      var panel = gift.querySelector('[data-gift-panel="' + key + '"]');
      if (panel) panel.classList.add('is-active');
    });
  });
})();
</script>


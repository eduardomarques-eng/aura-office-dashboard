{% comment %}Aura FAQ Accordion v1 — Sprint 11{% endcomment %}
<section class="aura-faq" id="AuraFAQ-{{ section.id }}">
  <div class="aura-faq__inner page-width">
    <div class="aura-faq__header">
      {%- if section.settings.kicker != blank -%}<span class="aura-faq__kicker">{{ section.settings.kicker }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="aura-faq__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="aura-faq__list">
      {%- for block in section.blocks -%}{%- if block.type == 'item' -%}
      <div class="aura-faq__item" {{ block.shopify_attributes }}>
        <button class="aura-faq__q" aria-expanded="false" aria-controls="AuraFAQA-{{ section.id }}-{{ forloop.index }}">
          <span class="aura-faq__q-text">{{ block.settings.question }}</span>
          <span class="aura-faq__q-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </button>
        <div class="aura-faq__a" id="AuraFAQA-{{ section.id }}-{{ forloop.index }}" hidden>
          <div class="aura-faq__a-inner">{{ block.settings.answer }}</div>
        </div>
      </div>
      {%- endif -%}{%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
    <div class="aura-faq__cta">
      <a href="{{ section.settings.cta_link | default: '/pages/faq' }}" class="aura-faq__cta-link">
        {{ section.settings.cta_label }}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    {%- endif -%}
  </div>
</section>
<style>
.aura-faq { padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; background:var(--aura-off-white,#FAFAF8); }
.aura-faq__inner { max-width:80rem; }
.aura-faq__header { text-align:center; margin-bottom:5.6rem; }
.aura-faq__kicker { display:block; font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase; color:var(--aura-terracota,#B8793A); margin-bottom:1.6rem; }
.aura-faq__heading { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:clamp(2.8rem,4vw,4rem); font-weight:400; font-style:italic; color:var(--aura-grafite,#3D3D3B); line-height:1.15; margin:0; }
.aura-faq__list { display:flex; flex-direction:column; }
.aura-faq__item { border-top:1px solid var(--aura-borda,#E2DBD4); }
.aura-faq__item:last-child { border-bottom:1px solid var(--aura-borda,#E2DBD4); }
.aura-faq__q { display:flex; align-items:center; justify-content:space-between; gap:2.4rem; width:100%; padding:2.4rem 0; background:none; border:none; cursor:pointer; text-align:left; }
.aura-faq__q-text { font-family:var(--font-heading-family,'Cormorant Garamond',serif); font-size:1.9rem; font-weight:400; color:var(--aura-grafite,#3D3D3B); line-height:1.3; flex:1; }
.aura-faq__q-icon { flex-shrink:0; color:var(--aura-terracota,#B8793A); transition:transform .35s cubic-bezier(.4,0,.2,1); display:flex; align-items:center; }
.aura-faq__q[aria-expanded="true"] .aura-faq__q-icon { transform:rotate(180deg); }
.aura-faq__a { overflow:hidden; transition:max-height .4s cubic-bezier(.4,0,.2,1); max-height:0; }
.aura-faq__a:not([hidden]) { max-height:60rem; }
.aura-faq__a-inner { font-family:var(--font-body-family); font-size:1.5rem; font-weight:300; color:var(--aura-cinza,#7A7A78); line-height:1.8; padding:0 0 2.4rem; }
.aura-faq__cta { text-align:center; margin-top:4.8rem; }
.aura-faq__cta-link { display:inline-flex; align-items:center; gap:.8rem; font-family:var(--font-body-family); font-size:1.1rem; font-weight:400; letter-spacing:.15em; text-transform:uppercase; color:var(--aura-grafite,#3D3D3B); text-decoration:none; border-bottom:1px solid var(--aura-grafite,#3D3D3B); padding-bottom:.3rem; transition:color .3s ease,border-color .3s ease; }
.aura-faq__cta-link:hover { color:var(--aura-terracota,#B8793A); border-color:var(--aura-terracota,#B8793A); }
.aura-faq__cta-link svg { transition:transform .3s ease; }
.aura-faq__cta-link:hover svg { transform:translateX(4px); }
@media(prefers-reduced-motion:reduce){ .aura-faq__q-icon,.aura-faq__a,.aura-faq__cta-link svg { transition:none!important; } }
</style>
<script>
(function(){
  var faq=document.getElementById('AuraFAQ-{{ section.id }}');
  if(!faq)return;
  faq.querySelectorAll('.aura-faq__q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var exp=this.getAttribute('aria-expanded')==='true';
      var panel=document.getElementById(this.getAttribute('aria-controls'));
      if(!panel)return;
      this.setAttribute('aria-expanded',exp?'false':'true');
      panel.hidden=exp;
    });
  });
})();
</script>
{% schema %}
{"name":"FAQ Accordion","tag":"section","class":"spaced-section","settings":[{"type":"text","id":"kicker","label":"Kicker","default":"Suporte"},{"type":"text","id":"heading","label":"Título","default":"Dúvidas frequentes"},{"type":"text","id":"cta_label","label":"Botão","default":"Ver todas as dúvidas"},{"type":"url","id":"cta_link","label":"Link"},{"type":"range","id":"padding_top","min":0,"max":120,"step":8,"unit":"px","label":"Espaço acima","default":96},{"type":"range","id":"padding_bottom","min":0,"max":120,"step":8,"unit":"px","label":"Espaço abaixo","default":96}],"blocks":[{"type":"item","name":"Pergunta","settings":[{"type":"text","id":"question","label":"Pergunta","default":"Qual o prazo de entrega?"},{"type":"richtext","id":"answer","label":"Resposta","default":"<p>Enviamos em até 3 dias úteis.<\/p>"}]}],"max_blocks":15,"presets":[{"name":"FAQ Accordion","blocks":[{"type":"item","settings":{"question":"Qual o prazo de entrega?","answer":"<p>Enviamos em até 3 dias úteis. O prazo de entrega varia conforme a região: Sudeste 5-10 dias, Sul 7-12 dias, demais regiões 10-20 dias úteis.<\/p>"}},{"type":"item","settings":{"question":"O frete é realmente grátis?","answer":"<p>Sim! Pedidos acima de R$ 299 têm frete grátis para todo o Brasil.<\/p>"}},{"type":"item","settings":{"question":"Como funciona a troca?","answer":"<p>Você tem 30 dias corridos para solicitar troca ou devolução. Entre em contato pelo WhatsApp ou email.<\/p>"}},{"type":"item","settings":{"question":"As peças são artesanais?","answer":"<p>Sim! Por serem artesanais, pode haver pequenas variações — o que é o charme do Wabi-Sabi. Cada peça é única.<\/p>"}},{"type":"item","settings":{"question":"Como é a embalagem?","answer":"<p>Papel de seda reciclado, lacre de cera artesanal e cartão manuscrito. A embalagem é parte da experiência Aura.<\/p>"}}]}]}
{% endschema %}
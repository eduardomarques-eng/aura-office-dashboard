{% comment %}Aura Video CTA v1 — Cinematic full-width belt com stats e CTAs{% endcomment %}

<section class="aura-vcta" id="AuraVCTA-{{ section.id }}">

  <div class="aura-vcta__media">
    {%- if section.settings.video_url != blank -%}
      <video class="aura-vcta__video" autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw" alt="{{ section.settings.image.alt | default: 'Aura Decore' }}"
        width="1920" height="1080" loading="lazy" class="aura-vcta__img">
    {%- elsif section.settings.bg_url != blank -%}
      <img src="{{ section.settings.bg_url }}" alt="Aura Decore"
        width="1920" height="1080" loading="lazy" class="aura-vcta__img">
    {%- endif -%}
    <div class="aura-vcta__overlay"></div>
  </div>

  <div class="aura-vcta__inner">
    {%- if section.settings.kicker != blank -%}
      <span class="aura-vcta__kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="aura-vcta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="aura-vcta__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- assign has_stats = false -%}
    {%- if section.settings.stat1_number != blank or section.settings.stat2_number != blank or section.settings.stat3_number != blank -%}
      {%- assign has_stats = true -%}
    {%- endif -%}
    {%- if has_stats -%}
    <div class="aura-vcta__stats">
      {%- if section.settings.stat1_number != blank -%}
        <div class="aura-vcta__stat">
          <span class="aura-vcta__stat-number">{{ section.settings.stat1_number }}</span>
          <span class="aura-vcta__stat-label">{{ section.settings.stat1_label }}</span>
        </div>
        {%- if section.settings.stat2_number != blank -%}<div class="aura-vcta__divider" aria-hidden="true"></div>{%- endif -%}
      {%- endif -%}
      {%- if section.settings.stat2_number != blank -%}
        <div class="aura-vcta__stat">
          <span class="aura-vcta__stat-number">{{ section.settings.stat2_number }}</span>
          <span class="aura-vcta__stat-label">{{ section.settings.stat2_label }}</span>
        </div>
        {%- if section.settings.stat3_number != blank -%}<div class="aura-vcta__divider" aria-hidden="true"></div>{%- endif -%}
      {%- endif -%}
      {%- if section.settings.stat3_number != blank -%}
        <div class="aura-vcta__stat">
          <span class="aura-vcta__stat-number">{{ section.settings.stat3_number }}</span>
          <span class="aura-vcta__stat-label">{{ section.settings.stat3_label }}</span>
        </div>
      {%- endif -%}
    </div>
    {%- endif -%}

    <div class="aura-vcta__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="aura-vcta__cta-primary">
          {{ section.settings.button_label }}
          <span class="aura-vcta__cta-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_link | default: '/pages/sobre' }}" class="aura-vcta__cta-ghost">
          {{ section.settings.button2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

</section>

<style>
#AuraVCTA-{{ section.id }} { min-height:{{ section.settings.height_desktop }}vh; }
@media(max-width:749px){ #AuraVCTA-{{ section.id }}{ min-height:{{ section.settings.height_mobile }}vh; } }

.aura-vcta {
  position:relative; overflow:hidden;
  display:flex; align-items:center; justify-content:center;
}
.aura-vcta__media { position:absolute; inset:0; }
.aura-vcta__img,.aura-vcta__video {
  width:100%; height:100%;
  object-fit:cover; object-position:center;
  display:block;
}
.aura-vcta__img {
  animation:aura-vcta-pan 24s ease-out infinite alternate;
}
@keyframes aura-vcta-pan {
  0%{ transform:scale(1) translate(0,0); }
  100%{ transform:scale(1.07) translate(-1.5%,1%); }
}
.aura-vcta__overlay {
  position:absolute; inset:0;
  background:
    linear-gradient(to bottom,
      rgba(45,38,32,.12) 0%,
      rgba(45,38,32,.55) 55%,
      rgba(45,38,32,.82) 100%);
}
.aura-vcta__inner {
  position:relative; z-index:2;
  text-align:center; max-width:88rem;
  padding:8rem 5%;
}
.aura-vcta__kicker {
  font-family:var(--font-body-family); font-size:1.1rem; font-weight:400;
  letter-spacing:.22em; text-transform:uppercase;
  color:rgba(250,250,248,.75);
  display:block; margin-bottom:2rem;
}
.aura-vcta__heading {
  font-family:var(--font-heading-family);
  font-size:clamp(3.6rem,5.5vw,7.2rem);
  font-weight:300; line-height:1.05;
  color:#FAFAF8; margin:0 0 2.4rem;
}
.aura-vcta__sub {
  font-family:var(--font-body-family);
  font-size:clamp(1.4rem,1.8vw,1.8rem);
  font-weight:300; line-height:1.65;
  color:rgba(250,250,248,.75);
  max-width:60rem; margin:0 auto 4.8rem;
}
/* Stats */
.aura-vcta__stats {
  display:flex; align-items:center; justify-content:center;
  gap:4rem; margin-bottom:5.6rem; flex-wrap:wrap;
}
@media(max-width:749px){ .aura-vcta__stats { gap:2.4rem; } }
.aura-vcta__stat { text-align:center; }
.aura-vcta__stat-number {
  font-family:var(--font-heading-family);
  font-size:clamp(3.6rem,5vw,5.6rem);
  font-weight:300; color:#FAFAF8; line-height:1; display:block;
}
.aura-vcta__stat-label {
  font-family:var(--font-body-family); font-size:1.1rem; font-weight:300;
  letter-spacing:.14em; text-transform:uppercase;
  color:rgba(250,250,248,.65);
  display:block; margin-top:.6rem;
}
.aura-vcta__divider {
  width:1px; height:5.6rem;
  background:rgba(250,250,248,.22);
}
@media(max-width:749px){ .aura-vcta__divider { display:none; } }
/* CTAs */
.aura-vcta__actions {
  display:flex; align-items:center; justify-content:center;
  gap:3.2rem; flex-wrap:wrap;
}
.aura-vcta__cta-primary {
  background:#FAFAF8; color:var(--aura-grafite,#3D3D3B);
  border:1.5px solid #FAFAF8;
  font-family:var(--font-body-family); font-size:1.1rem; font-weight:400;
  letter-spacing:.18em; text-transform:uppercase;
  padding:1.7rem 3.8rem; text-decoration:none;
  display:inline-flex; align-items:center; gap:1.2rem;
  position:relative; overflow:hidden;
  transition:background .35s ease,color .35s ease,border-color .35s ease;
}
.aura-vcta__cta-primary:hover {
  background:var(--aura-terracota,#B8793A);
  border-color:var(--aura-terracota,#B8793A);
  color:#FAFAF8;
}
.aura-vcta__cta-icon { display:flex; align-items:center; transition:transform .3s ease; }
.aura-vcta__cta-primary:hover .aura-vcta__cta-icon { transform:translateX(5px); }
.aura-vcta__cta-ghost {
  font-family:var(--font-body-family); font-size:1.1rem; font-weight:300;
  letter-spacing:.12em; color:rgba(250,250,248,.8);
  text-decoration:none;
  border-bottom:1px solid rgba(250,250,248,.4);
  padding-bottom:.2rem;
  transition:border-color .3s ease,color .3s ease;
}
.aura-vcta__cta-ghost:hover { border-color:rgba(250,250,248,.9); color:#FAFAF8; }
/* Reduced motion */
@media(prefers-reduced-motion:reduce){
  .aura-vcta__img { animation:none!important; }
}
</style>

{% schema %}
{
  "name": "Video CTA Cinematico",
  "tag": "section",
  "class": "aura-vcta-section",
  "settings": [
    {"type":"range","id":"height_desktop","min":40,"max":90,"step":5,"unit":"vh","label":"Altura desktop","default":65},
    {"type":"range","id":"height_mobile","min":40,"max":90,"step":5,"unit":"vh","label":"Altura mobile","default":60},
    {"type":"header","content":"Midia"},
    {"type":"text","id":"video_url","label":"URL do video MP4 (opcional)"},
    {"type":"image_picker","id":"image","label":"Imagem de fundo (upload)"},
    {"type":"text","id":"bg_url","label":"URL da imagem (CDN)"},
    {"type":"header","content":"Conteudo"},
    {"type":"text","id":"kicker","label":"Kicker","default":"Nossa Curadoria"},
    {"type":"text","id":"heading","label":"Titulo","default":"Criado para quem cuida do lar como obra de arte"},
    {"type":"textarea","id":"subheading","label":"Subtitulo"},
    {"type":"header","content":"Stats"},
    {"type":"text","id":"stat1_number","label":"Numero 1","default":"38"},
    {"type":"text","id":"stat1_label","label":"Label 1","default":"Produtos"},
    {"type":"text","id":"stat2_number","label":"Numero 2","default":"5"},
    {"type":"text","id":"stat2_label","label":"Label 2","default":"Colecoes"},
    {"type":"text","id":"stat3_number","label":"Numero 3","default":"100%"},
    {"type":"text","id":"stat3_label","label":"Label 3","default":"Embalagem Presente"},
    {"type":"header","content":"Botoes"},
    {"type":"text","id":"button_label","label":"Botao primario","default":"Ver Toda a Colecao"},
    {"type":"url","id":"button_link","label":"Link primario"},
    {"type":"text","id":"button2_label","label":"Botao ghost","default":"Nossa Historia"},
    {"type":"url","id":"button2_link","label":"Link ghost"}
  ],
  "presets": [{"name":"Video CTA Cinematico"}]
}
{% endschema %}
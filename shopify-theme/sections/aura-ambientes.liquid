{% comment %}
  Aura Ambientes v2 — Espaços de vida Japandi & Minimalismo
  Fix v2: position absolute + inset:0 nas imagens para eliminar stretching
{% endcomment %}

<section class="aura-ambientes" id="AuraAmbientes-{{ section.id }}">

  {%- if section.settings.show_hero -%}
  <div class="aura-ambientes__hero">
    {%- if section.settings.kicker != blank -%}
      <span class="aura-ambientes__hero-kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="aura-ambientes__hero-title">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="aura-ambientes__hero-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- assign idx_mod = forloop.index | modulo: 2 -%}
    <div class="aura-ambientes__item{% if idx_mod == 0 %} aura-ambientes__item--reverse{% endif %}"
         id="ambiente-{{ block.settings.slug | default: forloop.index }}"
         {{ block.shopify_attributes }}>

      <div class="aura-ambientes__media">
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 1920 }}"
            srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ block.settings.image.alt | default: block.settings.heading }}"
            width="1920" height="1280"
            loading="lazy"
            class="aura-ambientes__img">
        {%- elsif block.settings.bg_url != blank -%}
          <img
            src="{{ block.settings.bg_url }}"
            alt="{{ block.settings.heading | default: 'Ambiente Aura Decore' }}"
            width="1920" height="1280"
            loading="lazy"
            class="aura-ambientes__img">
        {%- endif -%}
        {%- if block.settings.ambiente_tag != blank -%}
          <span class="aura-ambientes__media-tag">{{ block.settings.ambiente_tag }}</span>
        {%- endif -%}
      </div>

      <div class="aura-ambientes__content">
        {%- if block.settings.kicker != blank -%}
          <span class="aura-ambientes__kicker">{{ block.settings.kicker }}</span>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          <h2 class="aura-ambientes__title">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <div class="aura-ambientes__desc">{{ block.settings.description }}</div>
        {%- endif -%}

        {%- assign has_f = false -%}
        {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
          {%- assign has_f = true -%}
        {%- endif -%}
        {%- if has_f -%}
          <ul class="aura-ambientes__features">
            {%- if block.settings.feature_1 != blank -%}<li class="aura-ambientes__feature">{{ block.settings.feature_1 }}</li>{%- endif -%}
            {%- if block.settings.feature_2 != blank -%}<li class="aura-ambientes__feature">{{ block.settings.feature_2 }}</li>{%- endif -%}
            {%- if block.settings.feature_3 != blank -%}<li class="aura-ambientes__feature">{{ block.settings.feature_3 }}</li>{%- endif -%}
          </ul>
        {%- endif -%}

        {%- if block.settings.cta_label != blank -%}
          <a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="aura-ambientes__cta">
            {{ block.settings.cta_label }}
            <span class="aura-ambientes__cta-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        {%- endif -%}
      </div>

    </div>
  {%- endfor -%}

</section>

<style>
.aura-ambientes { background:var(--color-background,#FAFAF8); }

.aura-ambientes__hero {
  text-align:center;
  padding:9.6rem 5% 6.4rem;
  max-width:80rem;
  margin:0 auto;
}
.aura-ambientes__hero-kicker {
  font-family:var(--font-body-family);
  font-size:1.1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase;
  color:var(--aura-terracota,#B8793A);
  display:block; margin-bottom:2rem;
}
.aura-ambientes__hero-title {
  font-family:var(--font-heading-family);
  font-size:clamp(3.6rem,5vw,7.2rem);
  font-weight:300; line-height:1.05;
  color:var(--aura-grafite,#3D3D3B);
  margin:0 0 2rem;
}
.aura-ambientes__hero-sub {
  font-family:var(--font-body-family);
  font-size:1.6rem; font-weight:300; line-height:1.65;
  color:var(--aura-cinza,#7A7A78);
  max-width:60rem; margin:0 auto;
}

/* Alternating layout */
.aura-ambientes__item {
  display:grid;
  grid-template-columns:1fr 1fr;
  min-height:56rem;
  border-top:1px solid rgba(61,61,59,.08);
}
.aura-ambientes__item--reverse { direction:rtl; }
.aura-ambientes__item--reverse > * { direction:ltr; }
@media(max-width:989px){
  .aura-ambientes__item { grid-template-columns:1fr; min-height:auto; }
  .aura-ambientes__item--reverse { direction:ltr; }
}

/* Media: position relative + altura que preenche a célula do grid */
.aura-ambientes__media {
  position:relative;
  overflow:hidden;
  /* height:100% garante preenchimento da célula grid */
  height:100%;
  min-height:44rem;
}
@media(max-width:989px){ .aura-ambientes__media { min-height:34rem; } }

/* FIX: position absolute + inset:0 + display:block elimina stretching */
.aura-ambientes__img {
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center;
  display:block;
  transition:transform .7s cubic-bezier(.4,0,.2,1);
}
.aura-ambientes__item:hover .aura-ambientes__img { transform:scale(1.04); }

.aura-ambientes__media-tag {
  position:absolute; top:2.4rem; left:2.4rem; z-index:1;
  background:rgba(250,250,248,.92); backdrop-filter:blur(8px);
  font-family:var(--font-body-family);
  font-size:1rem; font-weight:400; letter-spacing:.18em; text-transform:uppercase;
  color:var(--aura-grafite,#3D3D3B);
  padding:.6rem 1.4rem;
}

/* Content */
.aura-ambientes__content {
  display:flex; flex-direction:column; justify-content:center;
  padding:6.4rem 7.2rem;
}
@media(max-width:1199px){ .aura-ambientes__content { padding:4.8rem; } }
@media(max-width:749px){ .aura-ambientes__content { padding:4rem 2.4rem; } }

.aura-ambientes__kicker {
  font-family:var(--font-body-family);
  font-size:1rem; font-weight:400; letter-spacing:.22em; text-transform:uppercase;
  color:var(--aura-terracota,#B8793A);
  display:block; margin-bottom:1.6rem;
}
.aura-ambientes__title {
  font-family:var(--font-heading-family);
  font-size:clamp(2.8rem,3.5vw,4.8rem);
  font-weight:300; line-height:1.1;
  color:var(--aura-grafite,#3D3D3B);
  margin:0 0 2rem;
}
.aura-ambientes__desc {
  font-family:var(--font-body-family);
  font-size:1.4rem; font-weight:300; line-height:1.7;
  color:var(--aura-cinza,#7A7A78);
  margin-bottom:2.8rem;
}
.aura-ambientes__features {
  list-style:none; padding:0; margin:0 0 3.2rem;
  display:flex; flex-direction:column; gap:.8rem;
}
.aura-ambientes__feature {
  font-family:var(--font-body-family);
  font-size:1.2rem; font-weight:300; letter-spacing:.04em;
  color:var(--aura-grafite,#3D3D3B);
  padding-left:1.6rem; position:relative;
}
.aura-ambientes__feature::before {
  content:'\2014'; position:absolute; left:0;
  color:var(--aura-terracota,#B8793A); font-weight:400;
}

/* CTA */
.aura-ambientes__cta {
  display:inline-flex; align-items:center; gap:1.2rem;
  background:transparent;
  color:var(--aura-grafite,#3D3D3B);
  border:1.5px solid var(--aura-grafite,#3D3D3B);
  font-family:var(--font-body-family);
  font-size:1.1rem; font-weight:400; letter-spacing:.18em; text-transform:uppercase;
  padding:1.5rem 3.2rem; text-decoration:none; align-self:flex-start;
  transition:background .3s ease,color .3s ease,border-color .3s ease;
}
.aura-ambientes__cta:hover {
  background:var(--aura-terracota,#B8793A);
  border-color:var(--aura-terracota,#B8793A);
  color:#FAFAF8;
}
.aura-ambientes__cta-icon { display:flex; align-items:center; transition:transform .3s ease; }
.aura-ambientes__cta:hover .aura-ambientes__cta-icon { transform:translateX(4px); }

@media(prefers-reduced-motion:reduce){
  .aura-ambientes__img { transition:none!important; }
  .aura-ambientes__item:hover .aura-ambientes__img { transform:none; }
  .aura-ambientes__cta-icon { transition:none!important; }
}
</style>

{% schema %}
{
  "name": "Ambientes",
  "tag": "section",
  "class": "spaced-section--full-width",
  "settings": [
    {"type":"checkbox","id":"show_hero","label":"Exibir cabecalho","default":true},
    {"type":"text","id":"kicker","label":"Kicker","default":"Inspire-se"},
    {"type":"richtext","id":"heading","label":"Titulo","default":"<p>Ambientes que transformam<\/p>"},
    {"type":"text","id":"subheading","label":"Subtitulo","default":"Pecas para cada canto da sua casa com o olhar Japandi e a clareza do Minimalismo."}
  ],
  "blocks": [
    {
      "type": "ambiente",
      "name": "Ambiente",
      "settings": [
        {"type":"image_picker","id":"image","label":"Foto do ambiente"},
        {"type":"text","id":"bg_url","label":"URL da imagem CDN"},
        {"type":"text","id":"slug","label":"ID do ambiente","default":"sala"},
        {"type":"text","id":"ambiente_tag","label":"Tag sobre a imagem"},
        {"type":"text","id":"kicker","label":"Kicker"},
        {"type":"text","id":"heading","label":"Titulo do ambiente"},
        {"type":"richtext","id":"description","label":"Descricao"},
        {"type":"text","id":"feature_1","label":"Destaque 1"},
        {"type":"text","id":"feature_2","label":"Destaque 2"},
        {"type":"text","id":"feature_3","label":"Destaque 3"},
        {"type":"text","id":"cta_label","label":"Texto do botao","default":"Ver pecas para este espaco"},
        {"type":"url","id":"cta_link","label":"Link do botao"}
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{"name":"Ambientes"}]
}
{% endschema %}
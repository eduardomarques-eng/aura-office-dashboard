{% comment %}Aura Marquee v1 — Faixa de texto rolante Japandi — Sprint 11{% endcomment %}

<div class="aura-marquee" id="AuraMarquee-{{ section.id }}" aria-hidden="true" role="marquee">
  <div class="aura-marquee__track">
    {%- assign items = section.settings.text | split: '|' -%}
    {%- for i in (1..4) -%}
      {%- for item in items -%}
        {%- if item != blank -%}
        <span class="aura-marquee__item">
          <span class="aura-marquee__sep" aria-hidden="true">•</span>
          {{ item | strip }}
        </span>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

<style>
.aura-marquee {
  background: var(--aura-grafite, #3D3D3B);
  padding: 1.4rem 0;
  overflow: hidden;
}
.aura-marquee--light { background: var(--aura-linen, #EDE7DC); }
.aura-marquee--terracota { background: var(--aura-terracota, #B8793A); }
.aura-marquee__track {
  display: flex;
  align-items: center;
  width: max-content;
  animation: aura-marquee-scroll {{ section.settings.speed | default: 40 }}s linear infinite;
}
@keyframes aura-marquee-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.aura-marquee:hover .aura-marquee__track { animation-play-state: paused; }
.aura-marquee__item {
  display: inline-flex;
  align-items: center;
  gap: 2rem;
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  font-weight: 300;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(250,250,248,.75);
  white-space: nowrap;
  padding: 0 2.4rem;
}
.aura-marquee--light .aura-marquee__item { color: var(--aura-grafite, #3D3D3B); }
.aura-marquee--terracota .aura-marquee__item { color: rgba(250,250,248,.9); }
.aura-marquee__sep {
  color: var(--aura-terracota, #B8793A);
  font-size: 1.4rem;
}
.aura-marquee--light .aura-marquee__sep { color: var(--aura-terracota, #B8793A); }
.aura-marquee--terracota .aura-marquee__sep { color: rgba(250,250,248,.5); }
@media(prefers-reduced-motion:reduce){ .aura-marquee__track { animation: none; } }
</style>

{% schema %}
{
  "name": "Marquee Rolante",
  "tag": "div",
  "class": "aura-marquee-wrap",
  "settings": [
    {"type":"textarea","id":"text","label":"Itens (separar por |)","default":"Curadoria Japandi & Minimalismo | Peças que habitam com intenção | Design que permanece | Silêncio que fala | Wabi-Sabi | Handcrafted | Made with love"},
    {"type":"select","id":"style","label":"Estilo","options":[{"value":"dark","label":"Grafite escuro"},{"value":"light","label":"Linen claro"},{"value":"terracota","label":"Terracota"}],"default":"dark"},
    {"type":"range","id":"speed","min":10,"max":80,"step":5,"unit":"s","label":"Velocidade (s por ciclo)","default":40}
  ],
  "presets": [{"name":"Marquee Rolante"}]
}
{% endschema %}
{{ 'aura-lookbook.css' | asset_url | stylesheet_tag }}
{%- assign lookbook_src = section.settings.image_url -%}
<section class="aura-lookbook">
  <div class="page-width">
    <div class="aura-lookbook__header">
      <p class="aura-collections__label">I N S P I R A C A O</p>
      <h2 class="aura-collections__title">Ambientes que contam historias</h2>
    </div>
    <div class="aura-lookbook__grid">
      <div class="aura-lookbook__img">
        {%- if lookbook_src != blank -%}
        <img src="{{ lookbook_src }}" alt="Lookbook Aura Decore" loading="lazy" width="1200" height="800">
        {%- else -%}
        <img src="{{ 'lookbook.png' | asset_url }}" alt="Lookbook Aura Decore" loading="lazy" width="1200" height="800">
        {%- endif -%}
        <div class="aura-lookbook__hotspot" style="top:38%;left:28%"></div>
        <div class="aura-lookbook__hotspot" style="top:52%;left:55%"></div>
        <div class="aura-lookbook__hotspot" style="top:32%;left:72%"></div>
      </div>
      <div class="aura-lookbook__content">
        <p class="aura-collections__label">Lookbook</p>
        <h2>{{ section.settings.room_name }}</h2>
        <h3>{{ section.settings.room_style }}</h3>
        <p>{{ section.settings.description }}</p>
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="button">COMPRAR O LOOK</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{"name":"Aura Lookbook","settings":[{"type":"text","id":"image_url","label":"URL da imagem do lookbook"},{"type":"text","id":"room_name","label":"Room name","default":"Sala de Estar"},{"type":"text","id":"room_style","label":"Style name","default":"Silencio Dourado"},{"type":"textarea","id":"description","label":"Description","default":"Uma composicao de texturas naturais, tons terrosos e luz suave."},{"type":"url","id":"button_link","label":"Button link"}],"presets":[{"name":"Aura Lookbook"}]}
{% endschema %}
{% comment %}Aura Promessa v1 — Seção de garantias e diferenciais — Sprint 10{% endcomment %}

<section class="aura-promessa" id="AuraPromessa-{{ section.id }}">
  <div class="aura-promessa__inner page-width">
    {%- if section.settings.heading != blank -%}
    <div class="aura-promessa__header">
      {%- if section.settings.kicker != blank -%}
        <span class="aura-promessa__kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      <h2 class="aura-promessa__title">{{ section.settings.heading }}</h2>
    </div>
    {%- endif -%}
    <div class="aura-promessa__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
        <div class="aura-promessa__item" {{ block.shopify_attributes }}>
          <div class="aura-promessa__icon" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'truck' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 14h24v20H6V14zM30 20h7l5 7v7h-12V20z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="36" r="3" stroke="currentColor" stroke-width="2"/><circle cx="38" cy="36" r="3" stroke="currentColor" stroke-width="2"/></svg>
              {% when 'gift' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="20" width="36" height="22" rx="1" stroke="currentColor" stroke-width="2"/><rect x="4" y="13" width="40" height="8" rx="1" stroke="currentColor" stroke-width="2"/><path d="M24 13v29M24 13s-3-8-8-5c-4 2.5-1 8 8 5zM24 13s3-8 8-5c4 2.5 1 8-8 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              {% when 'refresh' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 24C8 15.163 15.163 8 24 8c5.334 0 10.065 2.614 13 6.632" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M40 24c0 8.837-7.163 16-16 16-5.334 0-10.065-2.614-13-6.632" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M37 8l3 7-7-1M11 40l-3-7 7 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {% when 'shield' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 5L8 12v12c0 10 7.2 17.4 16 21 8.8-3.6 16-11 16-21V12L24 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 24l5 5 9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {% when 'heart' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 41s-18-11-18-23a10 10 0 0120 0 10 10 0 0120 0C46 30 24 41 24 41z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {% when 'star' %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 5l5.878 11.91L44 18.82l-10 9.742L36.472 43 24 36.35 11.528 43 14 28.562 4 18.82l14.122-1.91L24 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {% else %}
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2"/><path d="M24 16v8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {% endcase %}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="aura-promessa__item-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.desc != blank -%}
            <p class="aura-promessa__item-desc">{{ block.settings.desc }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.aura-promessa {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--aura-grafite, #3D3D3B);
}
.aura-promessa__header {
  text-align: center;
  margin-bottom: 5.6rem;
}
.aura-promessa__kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 1.6rem;
}
.aura-promessa__title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.8rem, 4vw, 4.4rem);
  font-weight: 400;
  font-style: italic;
  color: var(--aura-off-white, #FAFAF8);
  line-height: 1.15;
  margin: 0;
}
.aura-promessa__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
  gap: 4rem;
}
@media (max-width: 749px) {
  .aura-promessa__grid { grid-template-columns: repeat(2, 1fr); gap: 3.2rem; }
}
.aura-promessa__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 2rem;
}
.aura-promessa__icon {
  width: 5.6rem;
  height: 5.6rem;
  color: var(--aura-terracota, #B8793A);
  flex-shrink: 0;
}
.aura-promessa__icon svg {
  width: 100%;
  height: 100%;
}
.aura-promessa__item-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: 2.2rem;
  font-weight: 400;
  color: var(--aura-off-white, #FAFAF8);
  line-height: 1.2;
  margin: 0;
}
.aura-promessa__item-desc {
  font-family: var(--font-body-family);
  font-size: 1.4rem;
  font-weight: 300;
  color: rgba(250,250,248,.65);
  line-height: 1.7;
  margin: 0;
}
</style>

{% schema %}
{
  "name": "Promessa Aura",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {"type":"text","id":"kicker","label":"Kicker","default":"Nossa promessa"},
    {"type":"text","id":"heading","label":"Título","default":"Porque somos diferentes"},
    {"type":"range","id":"padding_top","min":0,"max":120,"step":8,"unit":"px","label":"Espaço acima","default":96},
    {"type":"range","id":"padding_bottom","min":0,"max":120,"step":8,"unit":"px","label":"Espaço abaixo","default":96}
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item de Promessa",
      "settings": [
        {"type":"select","id":"icon","label":"ícone","options":[{"value":"truck","label":"Entrega"},{"value":"gift","label":"Presente"},{"value":"refresh","label":"Troca"},{"value":"shield","label":"Garantia"},{"value":"heart","label":"Amor"},{"value":"star","label":"Estrela"}],"default":"star"},
        {"type":"text","id":"title","label":"Título","default":"Curadoria Exclusiva"},
        {"type":"textarea","id":"desc","label":"Descrição","default":"Cada peça passa pelo nosso olhar crítico antes de chegar à loja."}
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Promessa Aura",
      "blocks": [
        {"type":"item","settings":{"icon":"star","title":"Curadoria Exclusiva","desc":"Cada peça é escolhida com intenção. Beleza, qualidade e propósito — nunca quantidade."}},
        {"type":"item","settings":{"icon":"gift","title":"Embalagem Presente","desc":"Papel de seda reciclado, lacre de cera artesanal e cartão manuscrito. Cada entrega é um ritual."}},
        {"type":"item","settings":{"icon":"truck","title":"Frete Grátis","desc":"Acima de R$ 299, seu pedido vem sem custo de envio. Entregamos em todo o Brasil."}},
        {"type":"item","settings":{"icon":"refresh","title":"Troca Grátis","desc":"30 dias para trocar sem burocracia. Sua satisfação é nossa única prioridade."}}
      ]
    }
  ]
}
{% endschema %}
{% comment %}Aura Filosofia v1 — Diptych Japandi & Minimalismo — Sprint 9{% endcomment %}

<section class="aura-filosofia" id="AuraFilosofia-{{ section.id }}">

  {%- if section.settings.kicker != blank or section.settings.heading != blank -%}
  <div class="aura-filosofia__intro page-width">
    {%- if section.settings.kicker != blank -%}
      <span class="aura-filosofia__intro-kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="aura-filosofia__intro-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="aura-filosofia__intro-sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
  {%- endif -%}

  <div class="aura-filosofia__grid page-width">
    {%- for block in section.blocks -%}
      {%- if block.type == 'filosofia' -%}
      <article class="aura-filosofia__card" {{ block.shopify_attributes }}>
        <div class="aura-filosofia__card-visual">
          {%- if block.settings.bg_url != blank -%}
            <img src="{{ block.settings.bg_url }}" alt="{{ block.settings.title | default: 'Aura Decore' }}" width="960" height="640" loading="lazy" class="aura-filosofia__card-img">
          {%- endif -%}
          {%- if block.settings.tag != blank -%}
            <div class="aura-filosofia__card-tag">{{ block.settings.tag }}</div>
          {%- endif -%}
        </div>
        <div class="aura-filosofia__card-body">
          {%- if block.settings.kicker != blank -%}
            <span class="aura-filosofia__card-kicker">{{ block.settings.kicker }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="aura-filosofia__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="aura-filosofia__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- assign has_features = false -%}
          {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
            {%- assign has_features = true -%}
          {%- endif -%}
          {%- if has_features -%}
          <ul class="aura-filosofia__card-features" aria-label="Princípios">
            {%- if block.settings.feature_1 != blank -%}<li>{{ block.settings.feature_1 }}</li>{%- endif -%}
            {%- if block.settings.feature_2 != blank -%}<li>{{ block.settings.feature_2 }}</li>{%- endif -%}
            {%- if block.settings.feature_3 != blank -%}<li>{{ block.settings.feature_3 }}</li>{%- endif -%}
          </ul>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <a href="{{ block.settings.cta_link | default: '/collections/all' }}" class="aura-filosofia__card-cta">
              <span>{{ block.settings.cta_label }}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- endif -%}
        </div>
      </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

<style>
.aura-filosofia {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--aura-linen, #F5F0EB);
}
.aura-filosofia__intro {
  text-align: center;
  max-width: 64rem;
  margin: 0 auto 6.4rem;
  padding: 0 2rem;
}
.aura-filosofia__intro-kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 1.6rem;
}
.aura-filosofia__intro-heading {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.8rem, 4vw, 4.4rem);
  font-weight: 400;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.15;
  margin: 0 0 2rem;
}
.aura-filosofia__intro-sub {
  font-family: var(--font-body-family);
  font-size: 1.6rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.7;
  margin: 0;
}
.aura-filosofia__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
}
@media (max-width: 899px) {
  .aura-filosofia__grid { grid-template-columns: 1fr; gap: 5.6rem; }
}
.aura-filosofia__card {
  display: flex;
  flex-direction: column;
  background: var(--aura-off-white, #FAFAF8);
  overflow: hidden;
}
.aura-filosofia__card-visual {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 2;
}
.aura-filosofia__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform .7s cubic-bezier(.4,0,.2,1);
  display: block;
}
.aura-filosofia__card:hover .aura-filosofia__card-img { transform: scale(1.04); }
.aura-filosofia__card-tag {
  position: absolute;
  top: 2rem;
  left: 2rem;
  font-family: var(--font-body-family);
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--aura-off-white, #FAFAF8);
  background: rgba(61,61,59,.65);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: .5rem 1.2rem;
}
.aura-filosofia__card-body {
  padding: 3.6rem 4rem 4rem;
  display: flex;
  flex-direction: column;
  gap: 1.6rem;
  flex: 1;
}
.aura-filosofia__card-kicker {
  font-family: var(--font-body-family);
  font-size: 1.05rem;
  font-weight: 400;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
}
.aura-filosofia__card-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3vw, 3.4rem);
  font-weight: 400;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.2;
  margin: 0;
}
.aura-filosofia__card-desc {
  font-family: var(--font-body-family);
  font-size: 1.5rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.75;
  margin: 0;
}
.aura-filosofia__card-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  border-top: 1px solid var(--aura-borda, #E2DBD4);
  padding-top: 2rem;
}
.aura-filosofia__card-features li {
  font-family: var(--font-body-family);
  font-size: 1.35rem;
  font-weight: 300;
  color: var(--aura-grafite, #3D3D3B);
  padding-left: 2rem;
  position: relative;
}
.aura-filosofia__card-features li::before {
  content: '\2014';
  position: absolute;
  left: 0;
  color: var(--aura-terracota, #B8793A);
  font-weight: 400;
}
.aura-filosofia__card-cta {
  display: inline-flex;
  align-items: center;
  gap: .8rem;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--aura-grafite, #3D3D3B);
  text-decoration: none;
  border-bottom: 1px solid var(--aura-grafite, #3D3D3B);
  padding-bottom: .3rem;
  margin-top: auto;
  align-self: flex-start;
  transition: color .3s ease, border-color .3s ease;
}
.aura-filosofia__card-cta:hover {
  color: var(--aura-terracota, #B8793A);
  border-color: var(--aura-terracota, #B8793A);
}
.aura-filosofia__card-cta svg { transition: transform .3s ease; flex-shrink: 0; }
.aura-filosofia__card-cta:hover svg { transform: translateX(4px); }
@media (prefers-reduced-motion: reduce) {
  .aura-filosofia__card-img,
  .aura-filosofia__card-cta svg { transition: none !important; }
  .aura-filosofia__card:hover .aura-filosofia__card-img { transform: none; }
}
</style>

{% schema %}
{
  "name": "Filosofia — Japandi",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {"type":"header","content":"Introducao"},
    {"type":"text","id":"kicker","label":"Kicker","default":"Nossa Essencia"},
    {"type":"text","id":"heading","label":"Titulo","default":"O espaco intencional comeca com uma escolha"},
    {"type":"textarea","id":"subheading","label":"Subtitulo","default":"Duas filosofias. Um objetivo comum: a beleza que serve."},
    {"type":"header","content":"Espacamento"},
    {"type":"range","id":"padding_top","min":0,"max":120,"step":8,"unit":"px","label":"Espaco acima","default":96},
    {"type":"range","id":"padding_bottom","min":0,"max":120,"step":8,"unit":"px","label":"Espaco abaixo","default":96}
  ],
  "blocks": [
    {
      "type": "filosofia",
      "name": "Bloco Filosofia",
      "settings": [
        {"type":"text","id":"tag","label":"Tag badge","default":"Japandi"},
        {"type":"text","id":"kicker","label":"Kicker","default":"Wabi-Sabi e Kanso"},
        {"type":"text","id":"title","label":"Titulo","default":"O silencio que fala"},
        {"type":"textarea","id":"description","label":"Descricao","default":"Japandi e a convergencia entre a sensibilidade japonesa e o design escandinavo."},
        {"type":"text","id":"feature_1","label":"Feature 1","default":"Materiais organicos — bambu, linho, ceramica"},
        {"type":"text","id":"feature_2","label":"Feature 2","default":"Paleta neutra — bege, terracota, cinza"},
        {"type":"text","id":"feature_3","label":"Feature 3","default":"Forma que segue a funcao"},
        {"type":"text","id":"cta_label","label":"Texto CTA","default":"Explorar"},
        {"type":"url","id":"cta_link","label":"Link CTA"},
        {"type":"text","id":"bg_url","label":"URL da imagem CDN"}
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [{"name":"Filosofia — Japandi"}]
}
{% endschema %}
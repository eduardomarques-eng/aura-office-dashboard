{% comment %}Aura Manifesto v1 — Página completa do manifesto — Sprint 10{% endcomment %}

<article class="aura-manifesto" id="AuraManifesto-{{ section.id }}">

  <!-- Hero cinemático -->
  <div class="aura-manifesto__hero">
    {%- if section.settings.hero_bg_url != blank -%}
      <img src="{{ section.settings.hero_bg_url }}" alt="Aura Decore Manifesto" width="1920" height="1080" loading="eager" fetchpriority="high" class="aura-manifesto__hero-img">
    {%- endif -%}
    <div class="aura-manifesto__hero-overlay"></div>
    <div class="aura-manifesto__hero-content">
      {%- if section.settings.hero_kicker != blank -%}
        <span class="aura-manifesto__hero-kicker">{{ section.settings.hero_kicker }}</span>
      {%- endif -%}
      {%- if section.settings.hero_heading != blank -%}
        <h1 class="aura-manifesto__hero-title">{{ section.settings.hero_heading }}</h1>
      {%- endif -%}
    </div>
  </div>

  <!-- Corpo do manifesto -->
  <div class="aura-manifesto__body page-width">
    <div class="aura-manifesto__intro">
      {%- if section.settings.intro_text != blank -%}
        <p class="aura-manifesto__lead">{{ section.settings.intro_text }}</p>
      {%- endif -%}
    </div>

    <!-- Blocos de princiípios -->
    {%- if section.blocks.size > 0 -%}
    <div class="aura-manifesto__principles">
      {%- for block in section.blocks -%}
        {%- if block.type == 'principio' -%}
        <div class="aura-manifesto__principle" {{ block.shopify_attributes }}>
          <span class="aura-manifesto__principle-num">0{{ forloop.index }}</span>
          <div class="aura-manifesto__principle-body">
            {%- if block.settings.title != blank -%}
              <h2 class="aura-manifesto__principle-title">{{ block.settings.title }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="aura-manifesto__principle-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- Citação final -->
    {%- if section.settings.closing_quote != blank -%}
    <blockquote class="aura-manifesto__closing">
      <p class="aura-manifesto__closing-text">“{{ section.settings.closing_quote }}”</p>
      {%- if section.settings.closing_author != blank -%}
        <cite class="aura-manifesto__closing-cite">— {{ section.settings.closing_author }}</cite>
      {%- endif -%}
    </blockquote>
    {%- endif -%}

    <!-- CTA final -->
    {%- if section.settings.cta_label != blank -%}
    <div class="aura-manifesto__cta-wrap">
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="aura-manifesto__cta">
        {{ section.settings.cta_label }}
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    {%- endif -%}
  </div>

</article>

<style>
.aura-manifesto {
  background: var(--aura-off-white, #FAFAF8);
}
/* Hero */
.aura-manifesto__hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: var(--aura-grafite, #3D3D3B);
}
.aura-manifesto__hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
  animation: manifesto-ken-burns 20s ease-out forwards;
}
@keyframes manifesto-ken-burns {
  0% { transform: scale(1); }
  100% { transform: scale(1.06) translate(-1%, -1%); }
}
.aura-manifesto__hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(45,38,32,.75) 0%, transparent 60%),
    linear-gradient(to right, rgba(45,38,32,.55) 0%, transparent 60%);
}
.aura-manifesto__hero-content {
  position: relative;
  z-index: 2;
  padding: 0 8% 7.2rem;
  max-width: 80rem;
}
.aura-manifesto__hero-kicker {
  display: block;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  margin-bottom: 2.4rem;
}
.aura-manifesto__hero-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(4rem, 7vw, 8rem);
  font-weight: 300;
  line-height: .95;
  letter-spacing: -.02em;
  color: var(--aura-off-white, #FAFAF8);
  margin: 0;
}
.aura-manifesto__hero-title em {
  font-style: italic;
  color: rgba(184,121,58,.9);
}
/* Body */
.aura-manifesto__body {
  padding: 9.6rem 0 12.8rem;
}
.aura-manifesto__intro {
  max-width: 72rem;
  margin: 0 auto 9.6rem;
  text-align: center;
  padding: 0 2rem;
}
.aura-manifesto__lead {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2rem, 2.8vw, 2.8rem);
  font-weight: 300;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.55;
  margin: 0;
}
/* Princípios */
.aura-manifesto__principles {
  display: flex;
  flex-direction: column;
  gap: 0;
  max-width: 84rem;
  margin: 0 auto;
}
.aura-manifesto__principle {
  display: grid;
  grid-template-columns: 8rem 1fr;
  gap: 4rem;
  padding: 5.6rem 0;
  border-top: 1px solid var(--aura-borda, #E2DBD4);
}
.aura-manifesto__principle:last-child {
  border-bottom: 1px solid var(--aura-borda, #E2DBD4);
}
@media (max-width: 749px) {
  .aura-manifesto__principle { grid-template-columns: 1fr; gap: 1.6rem; padding: 4rem 2rem; }
}
.aura-manifesto__principle-num {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: 5.6rem;
  font-weight: 300;
  color: var(--aura-terracota, #B8793A);
  opacity: .35;
  line-height: 1;
  padding-top: .4rem;
}
.aura-manifesto__principle-title {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3vw, 3.4rem);
  font-weight: 400;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.15;
  margin: 0 0 2rem;
}
.aura-manifesto__principle-text {
  font-family: var(--font-body-family);
  font-size: 1.6rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.8;
  margin: 0;
}
/* Citação final */
.aura-manifesto__closing {
  max-width: 72rem;
  margin: 9.6rem auto;
  text-align: center;
  padding: 0 2rem;
}
.aura-manifesto__closing-text {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3.5vw, 4rem);
  font-weight: 300;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.35;
  margin: 0 0 2.4rem;
}
.aura-manifesto__closing-cite {
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  font-weight: 400;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  font-style: normal;
}
/* CTA final */
.aura-manifesto__cta-wrap {
  text-align: center;
  margin-top: 6.4rem;
}
.aura-manifesto__cta {
  display: inline-flex;
  align-items: center;
  gap: 1.2rem;
  background: var(--aura-grafite, #3D3D3B);
  color: var(--aura-off-white, #FAFAF8);
  border: 1.5px solid var(--aura-grafite, #3D3D3B);
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: 1.8rem 4.4rem;
  text-decoration: none;
  transition: background .35s ease, border-color .35s ease;
}
.aura-manifesto__cta:hover {
  background: var(--aura-terracota, #B8793A);
  border-color: var(--aura-terracota, #B8793A);
}
.aura-manifesto__cta svg { transition: transform .3s ease; }
.aura-manifesto__cta:hover svg { transform: translateX(5px); }
@media (prefers-reduced-motion: reduce) {
  .aura-manifesto__hero-img { animation: none !important; }
  .aura-manifesto__cta svg { transition: none !important; }
}
</style>

{% schema %}
{
  "name": "Manifesto Aura",
  "tag": "section",
  "class": "spaced-section--full-width",
  "settings": [
    {"type":"header","content":"Hero"},
    {"type":"text","id":"hero_bg_url","label":"URL da imagem hero (CDN)"},
    {"type":"text","id":"hero_kicker","label":"Kicker","default":"M A N I F E S T O"},
    {"type":"text","id":"hero_heading","label":"Título hero","default":"Decoração é cuidado."},
    {"type":"header","content":"Introdução"},
    {"type":"textarea","id":"intro_text","label":"Texto de abertura","default":"Cada objeto que você escolhe para sua casa, escolhe você de volta. Acreditamos que sua casa pode te acalmar. Pode te inspirar. Pode te lembrar quem você é."},
    {"type":"header","content":"Citação Final"},
    {"type":"textarea","id":"closing_quote","label":"Citação","default":"Habitar com intenção é o ato mais íntimo de autoconhecimento."},
    {"type":"text","id":"closing_author","label":"Autor","default":"Aura Decore"},
    {"type":"header","content":"CTA Final"},
    {"type":"text","id":"cta_label","label":"Texto do botão","default":"Explorar a Curadoria"},
    {"type":"url","id":"cta_link","label":"Link do botão"}
  ],
  "blocks": [
    {
      "type": "principio",
      "name": "Princípio",
      "settings": [
        {"type":"text","id":"title","label":"Título","default":"A intenção antes do objeto"},
        {"type":"textarea","id":"text","label":"Texto","default":"Antes de comprar, pergunte: isso me faz sentir bem? Isso dura? Isso tem beleza que cresce com o tempo?"}
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Manifesto Aura",
      "blocks": [
        {"type":"principio","settings":{"title":"A intenção antes do objeto","text":"Cada peça que entra na sua casa carrega energia. Escolha com calça, com tempo, com intenção. O hábito de curar o próprio espaço é um hábito de autocuidado."}},
        {"type":"principio","settings":{"title":"O silencio como elemento de design","text":"Não existe vazio em um lar intencional. Existe espaço negativo — que dá respiro ao olhar, destaque ao que existe, e paz à mente que passa por ali."}},
        {"type":"principio","settings":{"title":"Beleza que não precisa se justificar","text":"Um vaso que não guarda nada. Uma pedra que foi recolhida na praia. Um ramo seco colocado com cuidado. Beleza que existe pelo simples prazer de existir."}},
        {"type":"principio","settings":{"title":"Durar é um ato revolucionário","text":"Em um mundo de descartáveis, escolher peças que durem é uma decisão política. A Aura Decore cuida cada peça para que você a herde, presente, memorize."}}
      ]
    }
  ]
}
{% endschema %}
{% comment %}
  Aura Carousel Banner v2 — Slides cinemáticos Japandi & Minimalismo
  Fix: object-fit cover com position absolute para eliminar stretching
{% endcomment %}

<section
  class="aura-carousel"
  id="AuraCarousel-{{ section.id }}"
  aria-label="Carrossel de banners"
  aria-roledescription="carrossel">

  <div class="aura-carousel__track">
    {%- for block in section.blocks -%}
      <div
        class="aura-carousel__slide{% if forloop.first %} is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} de {{ section.blocks.size }}">

        <div class="aura-carousel__media">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 2560 }}"
              srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1440 }} 1440w, {{ block.settings.image | image_url: width: 1920 }} 1920w, {{ block.settings.image | image_url: width: 2560 }} 2560w"
              sizes="100vw"
              alt="{{ block.settings.image.alt | default: block.settings.heading }}"
              width="2560" height="1440"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              class="aura-carousel__bg-img">
          {%- elsif block.settings.bg_url != blank -%}
            <img
              src="{{ block.settings.bg_url }}"
              alt="{{ block.settings.heading | default: 'Aura Decore' }}"
              width="2560" height="1440"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              class="aura-carousel__bg-img">
          {%- endif -%}
          <div class="aura-carousel__overlay"></div>
        </div>

        <div class="aura-carousel__content aura-carousel__content--{{ block.settings.content_position | default: 'left' }}">
          {%- if block.settings.kicker != blank -%}
            <span class="aura-carousel__kicker">{{ block.settings.kicker }}</span>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="aura-carousel__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subtext != blank -%}
            <p class="aura-carousel__sub">{{ block.settings.subtext }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_link | default: '/collections/all' }}"
              class="aura-carousel__cta">
              {{ block.settings.button_label }}
              <span class="aura-carousel__cta-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="aura-carousel__nav aura-carousel__nav--prev" aria-label="Slide anterior" data-carousel-prev>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 16.25L7.5 10L12.5 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="aura-carousel__nav aura-carousel__nav--next" aria-label="Próximo slide" data-carousel-next>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 3.75L12.5 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="aura-carousel__dots" role="tablist" aria-label="Slides">
      {%- for block in section.blocks -%}
        <button
          class="aura-carousel__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="Slide {{ forloop.index }}"
          data-carousel-dot="{{ forloop.index0 }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="aura-carousel__progress" aria-hidden="true">
    <div class="aura-carousel__progress-bar"></div>
  </div>

</section>

<style>
  #AuraCarousel-{{ section.id }} { min-height:{{ section.settings.height_desktop }}vh; }
  @media(max-width:749px){ #AuraCarousel-{{ section.id }}{ min-height:{{ section.settings.height_mobile }}vh; } }

  .aura-carousel { position:relative; overflow:hidden; background:var(--color-background,#FAFAF8); }
  .aura-carousel__track { position:relative; width:100%; min-height:inherit; }
  .aura-carousel__slide {
    position:absolute; inset:0; min-height:inherit;
    opacity:0; visibility:hidden; pointer-events:none;
    transition:opacity .9s cubic-bezier(.4,0,.2,1), visibility .9s;
    will-change:opacity;
  }
  .aura-carousel__slide.is-active { position:relative; opacity:1; visibility:visible; pointer-events:auto; }

  /* Media container: absolute fill */
  .aura-carousel__media { position:absolute; inset:0; overflow:hidden; }

  /* FIX: image absolute + inset:0 + display:block elimina stretching */
  .aura-carousel__bg-img {
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit:cover; object-position:center;
    display:block;
    transform:scale(1.06);
    transition:transform .9s cubic-bezier(.4,0,.2,1);
    will-change:transform; backface-visibility:hidden;
  }
  .aura-carousel__slide.is-active .aura-carousel__bg-img { transform:scale(1); }

  .aura-carousel__overlay {
    position:absolute; inset:0;
    background:
      linear-gradient(to right,rgba(245,240,235,.88) 0%,rgba(245,240,235,.52) 35%,rgba(245,240,235,.1) 60%,transparent 80%),
      linear-gradient(to top,rgba(45,38,32,.35) 0%,transparent 40%);
  }
  .aura-carousel__content {
    position:relative; z-index:2;
    height:100%; min-height:inherit;
    display:flex; flex-direction:column; justify-content:center;
    padding:0 8%; max-width:80rem;
  }
  .aura-carousel__content--center { margin:0 auto; align-items:center; text-align:center; }
  .aura-carousel__content--right { margin-left:auto; align-items:flex-end; text-align:right; }
  .aura-carousel__kicker {
    font-family:var(--font-body-family); font-size:1.1rem; font-weight:400;
    letter-spacing:.22em; text-transform:uppercase;
    color:#FAFAF8; background:var(--aura-terracota,#B8793A);
    padding:.5rem 1.4rem; display:inline-block; margin-bottom:2rem;
    transform:translateY(16px); opacity:0;
    transition:transform .65s cubic-bezier(.4,0,.2,1) .15s, opacity .65s ease .15s;
  }
  .aura-carousel__heading {
    font-family:var(--font-heading-family); font-size:clamp(3.2rem,5.5vw,7.2rem);
    font-weight:300; line-height:1.05; letter-spacing:-.01em;
    color:var(--aura-grafite,#3D3D3B); margin:0 0 2rem;
    transform:translateY(20px); opacity:0;
    transition:transform .7s cubic-bezier(.4,0,.2,1) .3s, opacity .7s ease .3s;
  }
  .aura-carousel__sub {
    font-family:var(--font-body-family); font-size:clamp(1.3rem,1.8vw,1.6rem);
    font-weight:300; line-height:1.65; color:var(--aura-cinza,#7A7A78);
    max-width:52rem; margin:0 0 3.6rem;
    transform:translateY(14px); opacity:0;
    transition:transform .65s cubic-bezier(.4,0,.2,1) .45s, opacity .65s ease .45s;
  }
  .aura-carousel__slide.is-active .aura-carousel__kicker,
  .aura-carousel__slide.is-active .aura-carousel__heading,
  .aura-carousel__slide.is-active .aura-carousel__sub,
  .aura-carousel__slide.is-active .aura-carousel__cta { transform:translateY(0); opacity:1; }
  .aura-carousel__cta {
    display:inline-flex; align-items:center; gap:1.2rem;
    background:var(--aura-grafite,#3D3D3B); color:#FAFAF8;
    border:1.5px solid var(--aura-grafite,#3D3D3B);
    font-family:var(--font-body-family); font-size:1.1rem; font-weight:400;
    letter-spacing:.18em; text-transform:uppercase;
    padding:1.7rem 3.8rem; text-decoration:none;
    position:relative; overflow:hidden; align-self:flex-start;
    transform:translateY(14px); opacity:0;
    transition:transform .65s cubic-bezier(.4,0,.2,1) .6s, opacity .65s ease .6s, background .35s ease, border-color .35s ease;
  }
  .aura-carousel__cta:hover { background:var(--aura-terracota,#B8793A); border-color:var(--aura-terracota,#B8793A); }
  .aura-carousel__cta::before {
    content:''; position:absolute; top:0; left:-60%; width:50%; height:100%;
    background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);
    transform:skewX(-15deg);
    animation:aura-shimmer-cta 3.5s ease-in-out infinite 2s;
  }
  @keyframes aura-shimmer-cta { 0%{left:-60%} 50%,100%{left:140%} }
  .aura-carousel__cta-icon { display:flex; align-items:center; transition:transform .3s ease; }
  .aura-carousel__cta:hover .aura-carousel__cta-icon { transform:translateX(5px); }
  .aura-carousel__nav {
    position:absolute; top:50%; transform:translateY(-50%); z-index:10;
    width:5.6rem; height:5.6rem;
    background:rgba(250,250,248,.88); backdrop-filter:blur(8px);
    border:1px solid rgba(61,61,59,.2); color:var(--aura-grafite,#3D3D3B);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; transition:background .3s ease,color .3s ease,border-color .3s ease;
  }
  .aura-carousel__nav:hover { background:var(--aura-grafite,#3D3D3B); color:#FAFAF8; border-color:var(--aura-grafite,#3D3D3B); }
  .aura-carousel__nav--prev { left:3.2rem; }
  .aura-carousel__nav--next { right:3.2rem; }
  @media(max-width:749px){
    .aura-carousel__nav { width:4.4rem; height:4.4rem; }
    .aura-carousel__nav--prev { left:1.2rem; }
    .aura-carousel__nav--next { right:1.2rem; }
    .aura-carousel__content { padding:0 5.6rem; }
  }
  .aura-carousel__dots { position:absolute; bottom:4rem; left:50%; transform:translateX(-50%); display:flex; gap:1.2rem; z-index:10; }
  .aura-carousel__dot {
    width:.8rem; height:.8rem; border-radius:50%;
    background:rgba(61,61,59,.3); border:none; cursor:pointer; padding:0;
    transition:background .3s ease,transform .3s ease,width .3s ease;
  }
  .aura-carousel__dot.is-active { background:var(--aura-terracota,#B8793A); transform:scale(1.3); width:2.4rem; border-radius:4px; }
  .aura-carousel__progress { position:absolute; bottom:0; left:0; right:0; height:2px; background:rgba(61,61,59,.12); z-index:10; }
  .aura-carousel__progress-bar { height:100%; width:0%; background:var(--aura-terracota,#B8793A); transition-property:width; transition-timing-function:linear; }
  @media(prefers-reduced-motion:reduce){
    .aura-carousel__slide,.aura-carousel__bg-img,.aura-carousel__kicker,.aura-carousel__heading,.aura-carousel__sub,.aura-carousel__cta { transition-duration:.01ms!important; animation:none!important; }
    .aura-carousel__kicker,.aura-carousel__heading,.aura-carousel__sub,.aura-carousel__cta { opacity:1; transform:none; }
  }
</style>

<script>
(function(){
  var carousel=document.getElementById('AuraCarousel-{{ section.id }}');
  if(!carousel)return;
  var slides=Array.from(carousel.querySelectorAll('.aura-carousel__slide'));
  var dots=Array.from(carousel.querySelectorAll('[data-carousel-dot]'));
  var bar=carousel.querySelector('.aura-carousel__progress-bar');
  var prevBtn=carousel.querySelector('[data-carousel-prev]');
  var nextBtn=carousel.querySelector('[data-carousel-next]');
  if(slides.length<=1)return;
  var current=0, timer=null;
  var dur={{ section.settings.autoplay_speed | default: 6000 }};
  var auto={{ section.settings.autoplay }};
  var reduced=window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  function go(i){
    slides[current].classList.remove('is-active');
    if(dots[current]){dots[current].classList.remove('is-active');dots[current].setAttribute('aria-selected','false');}
    current=((i%slides.length)+slides.length)%slides.length;
    slides[current].classList.add('is-active');
    if(dots[current]){dots[current].classList.add('is-active');dots[current].setAttribute('aria-selected','true');}
    if(bar&&auto&&!reduced){bar.style.transition='none';bar.style.width='0%';bar.offsetWidth;bar.style.transition='width '+dur+'ms linear';bar.style.width='100%';}
  }
  function start(){
    if(!auto||reduced)return;
    stop();
    timer=setInterval(function(){go(current+1);},dur);
    if(bar){bar.style.transition='none';bar.style.width='0%';bar.offsetWidth;bar.style.transition='width '+dur+'ms linear';bar.style.width='100%';}
  }
  function stop(){clearInterval(timer);if(bar){bar.style.transition='none';bar.style.width='0%';}}
  if(prevBtn)prevBtn.addEventListener('click',function(){go(current-1);start();});
  if(nextBtn)nextBtn.addEventListener('click',function(){go(current+1);start();});
  dots.forEach(function(d){d.addEventListener('click',function(){go(parseInt(d.dataset.carouselDot,10));start();});});
  var tx=0;
  carousel.addEventListener('touchstart',function(e){tx=e.touches[0].clientX;},{passive:true});
  carousel.addEventListener('touchend',function(e){var d=tx-e.changedTouches[0].clientX;if(Math.abs(d)>60){go(d>0?current+1:current-1);start();}},{passive:true});
  carousel.addEventListener('mouseenter',stop);
  carousel.addEventListener('mouseleave',start);
  carousel.addEventListener('focusin',stop);
  carousel.addEventListener('focusout',start);
  carousel.setAttribute('tabindex','0');
  carousel.addEventListener('keydown',function(e){if(e.key==='ArrowLeft'){go(current-1);start();}if(e.key==='ArrowRight'){go(current+1);start();}});
  start();
})();
</script>

{% schema %}
{
  "name": "Carrossel Banner",
  "tag": "section",
  "class": "aura-carousel-section",
  "settings": [
    {"type":"range","id":"height_desktop","min":40,"max":90,"step":5,"unit":"vh","label":"Altura desktop","default":65},
    {"type":"range","id":"height_mobile","min":40,"max":90,"step":5,"unit":"vh","label":"Altura mobile","default":55},
    {"type":"checkbox","id":"autoplay","label":"Avanco automatico","default":true},
    {"type":"range","id":"autoplay_speed","min":3000,"max":9000,"step":1000,"unit":"ms","label":"Velocidade ms","default":6000}
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {"type":"image_picker","id":"image","label":"Imagem upload Shopify"},
        {"type":"text","id":"bg_url","label":"URL da imagem CDN"},
        {"type":"text","id":"kicker","label":"Kicker","default":"Colecao 2026"},
        {"type":"text","id":"heading","label":"Titulo","default":"O espaco que respira"},
        {"type":"textarea","id":"subtext","label":"Subtitulo"},
        {"type":"text","id":"button_label","label":"Texto do botao","default":"Ir a Colecao"},
        {"type":"url","id":"button_link","label":"Link"},
        {"type":"select","id":"content_position","label":"Posicao","options":[{"value":"left","label":"Esquerda"},{"value":"center","label":"Centro"},{"value":"right","label":"Direita"}],"default":"left"}
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{"name":"Carrossel Banner"}]
}
{% endschema %}
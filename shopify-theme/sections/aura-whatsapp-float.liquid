{% comment %}Aura WhatsApp Float v1 — Botão flutuante WhatsApp — Sprint 11{% endcomment %}

{%- if section.settings.enabled and section.settings.phone != blank -%}
<div class="aura-wa" id="AuraWA-{{ section.id }}" role="complementary" aria-label="Contato via WhatsApp">
  <a
    href="https://wa.me/{{ section.settings.phone | remove: '+' | remove: '-' | remove: ' ' | remove: '(' | remove: ')' }}?text={{ section.settings.message | url_encode }}"
    class="aura-wa__btn"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Conversar no WhatsApp"
  >
    <svg class="aura-wa__icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    {%- if section.settings.show_label -%}
      <span class="aura-wa__label">{{ section.settings.label | default: 'Falar conosco' }}</span>
    {%- endif -%}
  </a>
  {%- if section.settings.show_tooltip -%}
  <div class="aura-wa__tooltip" role="tooltip">
    <strong>{{ section.settings.tooltip_title | default: 'Olá! Posso ajudar?' }}</strong>
    <span>{{ section.settings.tooltip_text | default: 'Fale com nossa equipe agora' }}</span>
  </div>
  {%- endif -%}
</div>

<style>
.aura-wa {
  position: fixed;
  bottom: {{ section.settings.bottom_offset }}rem;
  right: {{ section.settings.right_offset }}rem;
  z-index: 9990;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 1.2rem;
}
.aura-wa__btn {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: #25D366;
  color: #fff;
  border-radius: 5.6rem;
  padding: 1.4rem 2rem 1.4rem 1.6rem;
  box-shadow: 0 4px 24px rgba(37,211,102,.45), 0 2px 8px rgba(0,0,0,.18);
  text-decoration: none;
  transition: transform .3s cubic-bezier(.4,0,.2,1), box-shadow .3s ease, background .25s ease;
  position: relative;
  overflow: hidden;
}
.aura-wa__btn:hover {
  transform: translateY(-4px) scale(1.04);
  box-shadow: 0 8px 32px rgba(37,211,102,.55), 0 4px 16px rgba(0,0,0,.2);
  background: #20c45a;
}
/* Pulse ring */
.aura-wa__btn::before {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: inherit;
  background: #25D366;
  opacity: 0;
  animation: aura-wa-pulse 2.4s ease-out infinite 1.5s;
}
@keyframes aura-wa-pulse {
  0% { opacity: .4; transform: scale(1); }
  100% { opacity: 0; transform: scale(1.5); }
}
.aura-wa__icon {
  width: 2.6rem;
  height: 2.6rem;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.aura-wa__label {
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  font-weight: 500;
  letter-spacing: .04em;
  white-space: nowrap;
  position: relative;
  z-index: 1;
}
/* Tooltip */
.aura-wa__tooltip {
  background: var(--aura-grafite, #3D3D3B);
  color: var(--aura-off-white, #FAFAF8);
  border-radius: 1.2rem 1.2rem 0 1.2rem;
  padding: 1.4rem 1.8rem;
  max-width: 22rem;
  display: flex;
  flex-direction: column;
  gap: .4rem;
  box-shadow: 0 4px 24px rgba(61,61,59,.2);
  animation: aura-wa-tooltip-in .5s cubic-bezier(.4,0,.2,1) both;
  animation-delay: 2s;
  opacity: 0;
}
@keyframes aura-wa-tooltip-in {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.aura-wa__tooltip strong {
  font-family: var(--font-heading-family);
  font-size: 1.5rem;
  font-weight: 400;
  font-style: italic;
  color: var(--aura-off-white);
}
.aura-wa__tooltip span {
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  font-weight: 300;
  color: rgba(250,250,248,.7);
}
@media (max-width: 749px) {
  .aura-wa {
    bottom: 2rem;
    right: 1.6rem;
  }
  .aura-wa__label { display: none; }
  .aura-wa__btn { padding: 1.4rem; border-radius: 50%; }
  .aura-wa__tooltip { display: none; }
}
@media (prefers-reduced-motion: reduce) {
  .aura-wa__btn::before { animation: none; }
  .aura-wa__btn:hover { transform: none; }
  .aura-wa__tooltip { animation: none; opacity: 1; }
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "WhatsApp Flutuante",
  "tag": "div",
  "class": "aura-wa-section",
  "settings": [
    {"type":"checkbox","id":"enabled","label":"Ativar botão WhatsApp","default":true},
    {"type":"text","id":"phone","label":"Número WhatsApp (com DDD e DDI)","default":"+5585981957208","info":"Formato: +5511999999999"},
    {"type":"text","id":"message","label":"Mensagem inicial","default":"Olá! Vim pelo site Aura Decore e gostaria de saber mais sobre os produtos."},
    {"type":"checkbox","id":"show_label","label":"Exibir texto no botão","default":true},
    {"type":"text","id":"label","label":"Texto do botão","default":"Falar conosco"},
    {"type":"checkbox","id":"show_tooltip","label":"Exibir tooltip","default":true},
    {"type":"text","id":"tooltip_title","label":"Título do tooltip","default":"Olá! Posso ajudar?"},
    {"type":"text","id":"tooltip_text","label":"Texto do tooltip","default":"Fale com nossa equipe agora"},
    {"type":"range","id":"bottom_offset","min":2,"max":12,"step":1,"unit":"rem","label":"Distância do rodapé","default":4},
    {"type":"range","id":"right_offset","min":1,"max":8,"step":1,"unit":"rem","label":"Distância da direita","default":3}
  ],
  "presets": [{"name":"WhatsApp Flutuante"}]
}
{% endschema %}
{% comment %}Aura Popup Newsletter v1 — Popup de desconto com delay — Sprint 11{% endcomment %}

{%- if section.settings.enabled -%}
<div class="aura-popup" id="AuraPopup-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Newsletter Aura Decore" hidden>
  <div class="aura-popup__backdrop" id="AuraPopupBackdrop-{{ section.id }}"></div>
  <div class="aura-popup__box">
    <button class="aura-popup__close" id="AuraPopupClose-{{ section.id }}" aria-label="Fechar popup">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
    <div class="aura-popup__visual">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 480 }}" alt="Aura Decore" width="480" height="600" loading="lazy" class="aura-popup__img">
      {%- elsif section.settings.image_url != blank -%}
        <img src="{{ section.settings.image_url }}" alt="Aura Decore" width="480" height="600" loading="lazy" class="aura-popup__img">
      {%- else -%}
        <div class="aura-popup__img-placeholder"></div>
      {%- endif -%}
    </div>
    <div class="aura-popup__content">
      {%- if section.settings.badge != blank -%}
        <div class="aura-popup__badge">{{ section.settings.badge }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="aura-popup__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="aura-popup__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.coupon != blank -%}
        <div class="aura-popup__coupon">
          <span class="aura-popup__coupon-label">Seu cupom:</span>
          <button class="aura-popup__coupon-code" id="AuraPopupCoupon-{{ section.id }}" onclick="navigator.clipboard.writeText('{{ section.settings.coupon }}').then(()=>{this.textContent='Copiado! ✓';setTimeout(()=>{this.textContent='{{ section.settings.coupon }}'},2000)})" title="Clique para copiar">
            {{ section.settings.coupon }}
          </button>
        </div>
      {%- endif -%}
      <form class="aura-popup__form" action="/contact#contact_form" method="post">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="&#x2713;">
        <div class="aura-popup__field">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.input_placeholder | default: 'seu@email.com' }}" required class="aura-popup__input" autocomplete="email">
          <button type="submit" class="aura-popup__submit">{{ section.settings.button_label | default: 'Quero meu desconto' }}</button>
        </div>
      </form>
      {%- if section.settings.disclaimer != blank -%}
        <p class="aura-popup__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
      <button class="aura-popup__skip" id="AuraPopupSkip-{{ section.id }}">{{ section.settings.skip_label | default: 'Continuar sem desconto' }}</button>
    </div>
  </div>
</div>

<style>
.aura-popup {
  position: fixed;
  inset: 0;
  z-index: 9995;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}
.aura-popup[hidden] { display: none; }
.aura-popup__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(45,38,32,.72);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  cursor: pointer;
}
.aura-popup__box {
  position: relative;
  background: var(--aura-off-white, #FAFAF8);
  max-width: 80rem;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  animation: aura-popup-in .5s cubic-bezier(.16,1,.3,1) both;
  overflow: hidden;
  max-height: 90vh;
}
@keyframes aura-popup-in {
  from { opacity: 0; transform: scale(.94) translateY(16px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
@media (max-width: 649px) {
  .aura-popup__box { grid-template-columns: 1fr; max-width: 42rem; }
}
.aura-popup__close {
  position: absolute;
  top: 1.6rem;
  right: 1.6rem;
  z-index: 2;
  background: rgba(250,250,248,.9);
  border: none;
  cursor: pointer;
  padding: .8rem;
  color: var(--aura-grafite, #3D3D3B);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color .25s ease;
}
.aura-popup__close:hover { color: var(--aura-terracota, #B8793A); }
.aura-popup__visual {
  background: var(--aura-linen, #EDE7DC);
  overflow: hidden;
}
@media (max-width: 649px) { .aura-popup__visual { display: none; } }
.aura-popup__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.aura-popup__img-placeholder {
  width: 100%;
  height: 100%;
  min-height: 40rem;
  background: linear-gradient(135deg, var(--aura-linen) 0%, var(--aura-beige, #F5F0EB) 100%);
}
.aura-popup__content {
  padding: 4.8rem 4rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
  overflow-y: auto;
}
@media (max-width: 749px) { .aura-popup__content { padding: 4rem 2.8rem; } }
.aura-popup__badge {
  display: inline-block;
  font-family: var(--font-body-family);
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--aura-terracota, #B8793A);
  border: 1px solid var(--aura-terracota, #B8793A);
  padding: .4rem 1.2rem;
  align-self: flex-start;
}
.aura-popup__heading {
  font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 3.5vw, 3.6rem);
  font-weight: 400;
  font-style: italic;
  color: var(--aura-grafite, #3D3D3B);
  line-height: 1.15;
  margin: 0;
}
.aura-popup__sub {
  font-family: var(--font-body-family);
  font-size: 1.4rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.7;
  margin: 0;
}
.aura-popup__coupon {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  flex-wrap: wrap;
}
.aura-popup__coupon-label {
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--aura-cinza, #7A7A78);
}
.aura-popup__coupon-code {
  background: var(--aura-linen, #EDE7DC);
  border: 1.5px dashed var(--aura-terracota, #B8793A);
  color: var(--aura-terracota, #B8793A);
  font-family: var(--font-body-family);
  font-size: 1.6rem;
  font-weight: 500;
  letter-spacing: .2em;
  padding: .8rem 1.6rem;
  cursor: pointer;
  transition: background .25s ease;
}
.aura-popup__coupon-code:hover { background: var(--aura-beige, #F5F0EB); }
.aura-popup__field {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.aura-popup__input {
  width: 100%;
  padding: 1.4rem 1.6rem;
  border: 1px solid var(--aura-borda, #E2DBD4);
  background: transparent;
  font-family: var(--font-body-family);
  font-size: 1.4rem;
  font-weight: 300;
  color: var(--aura-grafite, #3D3D3B);
  border-radius: 0;
  outline: none;
  transition: border-color .25s ease;
}
.aura-popup__input:focus { border-color: var(--aura-grafite, #3D3D3B); }
.aura-popup__submit {
  background: var(--aura-grafite, #3D3D3B);
  color: var(--aura-off-white, #FAFAF8);
  border: none;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: 1.6rem 2.4rem;
  cursor: pointer;
  width: 100%;
  transition: background .3s ease;
}
.aura-popup__submit:hover { background: var(--aura-terracota, #B8793A); }
.aura-popup__disclaimer {
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  line-height: 1.6;
  margin: 0;
}
.aura-popup__skip {
  background: none;
  border: none;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 300;
  color: var(--aura-cinza, #7A7A78);
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 3px;
  padding: 0;
  align-self: center;
  transition: color .25s ease;
}
.aura-popup__skip:hover { color: var(--aura-grafite, #3D3D3B); }
@media (prefers-reduced-motion: reduce) {
  .aura-popup__box { animation: none; }
}
</style>

<script>
(function() {
  var POPUP_KEY = 'aura_popup_{{ section.id }}_dismissed';
  var POPUP_DELAY = {{ section.settings.delay_seconds | default: 5 }} * 1000;
  var popup = document.getElementById('AuraPopup-{{ section.id }}');
  var closeBtn = document.getElementById('AuraPopupClose-{{ section.id }}');
  var backdrop = document.getElementById('AuraPopupBackdrop-{{ section.id }}');
  var skipBtn = document.getElementById('AuraPopupSkip-{{ section.id }}');
  if (!popup) return;
  function dismiss() {
    popup.hidden = true;
    try { sessionStorage.setItem(POPUP_KEY, '1'); } catch(e) {}
  }
  function show() {
    try { if (sessionStorage.getItem(POPUP_KEY)) return; } catch(e) {}
    popup.hidden = false;
    popup.querySelector('.aura-popup__input') && popup.querySelector('.aura-popup__input').focus();
  }
  if (closeBtn) closeBtn.addEventListener('click', dismiss);
  if (backdrop) backdrop.addEventListener('click', dismiss);
  if (skipBtn) skipBtn.addEventListener('click', dismiss);
  popup.addEventListener('keydown', function(e) { if (e.key === 'Escape') dismiss(); });
  setTimeout(show, POPUP_DELAY);
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Popup Newsletter",
  "tag": "div",
  "class": "aura-popup-section",
  "settings": [
    {"type":"checkbox","id":"enabled","label":"Ativar popup","default":true},
    {"type":"range","id":"delay_seconds","min":2,"max":30,"step":1,"unit":"s","label":"Delay antes de aparecer","default":6},
    {"type":"header","content":"Imagem"},
    {"type":"image_picker","id":"image","label":"Imagem (upload)"},
    {"type":"text","id":"image_url","label":"URL da imagem (CDN)"},
    {"type":"header","content":"Conteúdo"},
    {"type":"text","id":"badge","label":"Badge","default":"Oferta exclusiva"},
    {"type":"text","id":"heading","label":"Título","default":"10% de desconto na primeira compra"},
    {"type":"textarea","id":"subtext","label":"Subtexto","default":"Inscreva-se e receba inspirações Japandi + um cupom exclusivo para estrear na Aura Decore."},
    {"type":"text","id":"coupon","label":"Código do cupom","default":"BEMVINDO10"},
    {"type":"text","id":"input_placeholder","label":"Placeholder do e-mail","default":"seu@email.com"},
    {"type":"text","id":"button_label","label":"Texto do botão","default":"Quero meu desconto"},
    {"type":"text","id":"disclaimer","label":"Rodapé","default":"Sem spam. Só beleza intencional, uma vez por semana."},
    {"type":"text","id":"skip_label","label":"Texto de pular","default":"Continuar sem desconto"}
  ],
  "presets": [{"name":"Popup Newsletter"}]
}
{% endschema %}
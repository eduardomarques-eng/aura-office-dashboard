{% comment %}
  Aura Decore — Instagram Widget (clone do Siga-nos Instagram da Dcorada)
  Usa SnapWidget ou embed básico
{% endcomment %}

<style>
  .aura-instagram {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    text-align: center;
  }
  .aura-instagram__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .aura-instagram__header {
    margin-bottom: 28px;
  }
  .aura-instagram__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: {{ section.settings.title_color }};
    margin: 0 0 8px;
  }
  .aura-instagram__handle {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    text-decoration: none;
  }
  .aura-instagram__handle:hover { text-decoration: underline; }
  .aura-instagram__widget {
    width: 100%;
    overflow: hidden;
  }
  .aura-instagram__widget iframe {
    width: 100% !important;
    border: none !important;
  }
  /* Grid manual para preview (caso sem widget) */
  .aura-instagram__preview-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
  }
  .aura-instagram__preview-item {
    aspect-ratio: 1/1;
    background: #E8E0D4;
    overflow: hidden;
    position: relative;
  }
  .aura-instagram__preview-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .aura-instagram__preview-item:hover img { transform: scale(1.06); }
  .aura-instagram__preview-item a {
    display: block; width: 100%; height: 100%;
    position: absolute; inset: 0;
    background: rgba(26,26,26,0);
    transition: background 0.3s;
  }
  .aura-instagram__preview-item:hover a { background: rgba(26,26,26,0.12); }
  @media (max-width: 749px) {
    .aura-instagram__preview-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<div class="aura-instagram">
  <div class="aura-instagram__inner">
    <div class="aura-instagram__header">
      <h2 class="aura-instagram__title">{{ section.settings.titulo }}</h2>
      {% if section.settings.instagram_handle != blank %}
      <a href="https://instagram.com/{{ section.settings.instagram_handle | remove: '@' }}" target="_blank" rel="noopener" class="aura-instagram__handle">@{{ section.settings.instagram_handle | remove: '@' }}</a>
      {% endif %}
    </div>

    {% if section.settings.snapwidget_token != blank %}
    <div class="aura-instagram__widget">
      <script src="https://snapwidget.com/js/snapwidget.js"></script>
      <iframe
        src="https://snapwidget.com/embed/{{ section.settings.snapwidget_token }}"
        class="snapwidget-widget"
        allowtransparency="true"
        frameborder="0"
        scrolling="no"
        style="border:none;overflow:hidden;width:100%;"
        title="Posts from Instagram"
      ></iframe>
    </div>
    {% else %}
    {%- comment %} Fallback: grid com imagens manuais {%- endcomment %}
    <div class="aura-instagram__preview-grid">
      {% for block in section.blocks %}
        {% if block.type == 'foto' %}
        <div class="aura-instagram__preview-item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 400 }}"
                 alt="{{ block.settings.image.alt | default: 'Instagram Aura Decore' }}"
                 loading="lazy" width="400" height="400">
          {% else %}
            <div style="background:linear-gradient(135deg,#E8E0D4,#C9B99A);width:100%;height:100%;"></div>
          {% endif %}
          {% if section.settings.instagram_handle != blank %}
          <a href="https://instagram.com/{{ section.settings.instagram_handle | remove: '@' }}" target="_blank" rel="noopener" aria-label="Ver no Instagram"></a>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Aura — Instagram",
  "blocks": [
    {
      "type": "foto",
      "name": "Foto Instagram",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da seção",
      "default": "Siga-nos no Instagram"
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "@ do Instagram",
      "default": "@auradecore"
    },
    {
      "type": "text",
      "id": "snapwidget_token",
      "label": "Token SnapWidget (opcional)",
      "info": "Cole o token do seu SnapWidget para feed automático. Deixe vazio para usar grade manual."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#F0EAE0"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor de destaque",
      "default": "#B8976A"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaço superior",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaço inferior",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Aura — Instagram",
      "blocks": [
        { "type": "foto" }, { "type": "foto" },
        { "type": "foto" }, { "type": "foto" },
        { "type": "foto" }, { "type": "foto" }
      ]
    }
  ]
}
{% endschema %}

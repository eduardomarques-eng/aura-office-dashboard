{% comment %}
  Aura Decore — Seção Reviews Premium abaixo do produto
{% endcomment %}

{%- liquid
  assign review_count = product.metafields.aura.review_count.value | default: '87'
  assign review_rating = product.metafields.aura.review_rating.value | default: '4.9'
-%}

<div
  class="aura-reviews page-width"
  id="AuraReviews-{{ section.id }}"
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;"
>
  <div style="border-top:2px solid #E2DBD2;padding-top:4.8rem">

    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:2.4rem;margin-bottom:4.8rem">
      <div>
        <p style="font-size:1rem;letter-spacing:.22em;text-transform:uppercase;color:#B8793A;margin:0 0 1.2rem">Avaliações verificadas</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:3.2rem;font-weight:400;color:#3D3D3B;margin:0 0 .8rem;line-height:1.1">O que dizem<br>nossas clientes</h2>
        <p style="font-size:1.4rem;font-weight:300;color:#8A8580;margin:0">Compras verificadas. Experiências reais.</p>
      </div>
      <div style="text-align:center;background:#F5F0EB;padding:2.4rem 3.2rem">
        <div style="font-family:'Cormorant Garamond',serif;font-size:5.6rem;font-weight:400;color:#B8793A;line-height:1">{{ review_rating }}</div>
        <div style="display:flex;gap:.4rem;margin:.8rem 0;justify-content:center;font-size:1.6rem">⭐⭐⭐⭐⭐</div>
        <p style="font-size:1.2rem;color:#8A8580;margin:0">{{ review_count }} avaliações</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2.4rem;margin-bottom:4.8rem">

      {%- assign reviews = product.metafields.aura.reviews.value -%}
      {%- if reviews -%}
        {%- for review in reviews -%}
        <div style="background:#F5F0EB;padding:3.2rem;border-left:3px solid #B8793A">
          <div style="font-size:1.3rem;margin-bottom:1.6rem">⭐⭐⭐⭐⭐</div>
          <p style="font-size:1.4rem;font-style:italic;line-height:1.85;color:#3D3D3B;margin:0 0 2rem">&ldquo;{{ review.text }}&rdquo;</p>
          <div>
            <p style="font-size:1.2rem;font-weight:500;color:#B8793A;margin:0">{{ review.author }}</p>
            <p style="font-size:1.1rem;color:#8A8580;margin:.4rem 0 0">{{ review.city }} • Compra verificada</p>
          </div>
        </div>
        {%- endfor -%}
      {%- else -%}

        <div style="background:#F5F0EB;padding:3.2rem;border-left:3px solid #B8793A">
          <div style="font-size:1.3rem;margin-bottom:1.6rem">⭐⭐⭐⭐⭐</div>
          <p style="font-size:1.4rem;font-style:italic;line-height:1.85;color:#3D3D3B;margin:0 0 2rem">&ldquo;Fiquei sem palavras. A qualidade é incrível, muito melhor ao vivo do que nas fotos. A embalagem com lacre de cera já é uma experiência. Amei cada detalhe.&rdquo;</p>
          <div>
            <p style="font-size:1.2rem;font-weight:500;color:#B8793A;margin:0">Fernanda M.</p>
            <p style="font-size:1.1rem;color:#8A8580;margin:.4rem 0 0">São Paulo, SP &bull; Compra verificada</p>
          </div>
        </div>

        <div style="background:#F5F0EB;padding:3.2rem;border-left:3px solid #B8793A">
          <div style="font-size:1.3rem;margin-bottom:1.6rem">⭐⭐⭐⭐⭐</div>
          <p style="font-size:1.4rem;font-style:italic;line-height:1.85;color:#3D3D3B;margin:0 0 2rem">&ldquo;Comprei para presentear minha mãe e ela ficou emocionada. O produto tem alma verdadeira. Dá para sentir o cuidado em cada detalhe artesanal. Perfeito.&rdquo;</p>
          <div>
            <p style="font-size:1.2rem;font-weight:500;color:#B8793A;margin:0">Carla S.</p>
            <p style="font-size:1.1rem;color:#8A8580;margin:.4rem 0 0">Curitiba, PR &bull; Compra verificada</p>
          </div>
        </div>

        <div style="background:#F5F0EB;padding:3.2rem;border-left:3px solid #B8793A">
          <div style="font-size:1.3rem;margin-bottom:1.6rem">⭐⭐⭐⭐⭐</div>
          <p style="font-size:1.4rem;font-style:italic;line-height:1.85;color:#3D3D3B;margin:0 0 2rem">&ldquo;Minha sala ficou completamente diferente. É raro encontrar decoração com essa qualidade aqui no Brasil. Já é a terceira vez que compro na Aura Decore.&rdquo;</p>
          <div>
            <p style="font-size:1.2rem;font-weight:500;color:#B8793A;margin:0">Bianca L.</p>
            <p style="font-size:1.1rem;color:#8A8580;margin:.4rem 0 0">Rio de Janeiro, RJ &bull; Compra verificada &bull; 3ª compra</p>
          </div>
        </div>

      {%- endif -%}
    </div>

    <div style="display:flex;gap:4rem;align-items:center;padding:2.4rem 0;border-top:1px solid #E2DBD2;flex-wrap:wrap">
      <div style="display:flex;align-items:center;gap:1.2rem">
        <span style="font-size:2rem">📦</span>
        <div><p style="font-size:1.2rem;font-weight:500;color:#3D3D3B;margin:0">Entrega Segura</p><p style="font-size:1.1rem;color:#8A8580;margin:0">Embalagem premium inclusa</p></div>
      </div>
      <div style="display:flex;align-items:center;gap:1.2rem">
        <span style="font-size:2rem">🔄</span>
        <div><p style="font-size:1.2rem;font-weight:500;color:#3D3D3B;margin:0">Troca Grátis 30 dias</p><p style="font-size:1.1rem;color:#8A8580;margin:0">Sem burocracia</p></div>
      </div>
      <div style="display:flex;align-items:center;gap:1.2rem">
        <span style="font-size:2rem">✨</span>
        <div><p style="font-size:1.2rem;font-weight:500;color:#3D3D3B;margin:0">Curadoria Artesanal</p><p style="font-size:1.1rem;color:#8A8580;margin:0">Selecionado com intenção</p></div>
      </div>
      <div style="display:flex;align-items:center;gap:1.2rem">
        <span style="font-size:2rem">🇧🇷</span>
        <div><p style="font-size:1.2rem;font-weight:500;color:#3D3D3B;margin:0">Frete Grátis</p><p style="font-size:1.1rem;color:#8A8580;margin:0">Acima de R$ 299</p></div>
      </div>
    </div>

  </div>
</div>

<style>
  .aura-reviews { max-width: var(--page-width); margin: 0 auto; padding-left: 1.5rem; padding-right: 1.5rem; }
  @media (min-width: 750px) { .aura-reviews { padding-left: 5rem; padding-right: 5rem; } }
  @media (max-width: 749px) {
    .aura-reviews [style*='grid-template-columns:repeat(3'] { grid-template-columns: 1fr !important; }
    .aura-reviews [style*='display:flex;align-items:flex-start'] { flex-direction: column; }
  }
</style>

{% schema %}
{
  "name": "Aura Reviews",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding superior", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 8, "unit": "px", "label": "Padding inferior", "default": 64 }
  ],
  "presets": [{ "name": "Aura Reviews" }]
}
{% endschema %}

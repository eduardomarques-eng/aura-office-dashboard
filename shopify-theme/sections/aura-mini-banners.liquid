{% comment %}
  Aura Decore — Mini Banners 3 colunas (clone dos mini banners da Dcorada)
  Aparece abaixo do slider principal
{% endcomment %}

<style>
  .aura-mini-banners {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }
  .aura-mini-banners__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }
  .aura-mini-banner-item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    display: block;
    text-decoration: none;
  }
  .aura-mini-banner-item img {
    width: 100%;
    height: {{ section.settings.item_height }}px;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .aura-mini-banner-item:hover img { transform: scale(1.04); }
  .aura-mini-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.55) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
    transition: background 0.3s;
  }
  .aura-mini-banner-item:hover .aura-mini-banner-overlay {
    background: linear-gradient(to top, rgba(26,26,26,0.65) 0%, rgba(26,26,26,0.1) 70%);
  }
  .aura-mini-banner-label {
    color: #F0EAE0;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.2;
    margin: 0 0 4px;
  }
  .aura-mini-banner-sub {
    color: rgba(240,234,224,0.8);
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }
  .aura-mini-banner-cta {
    display: inline-block;
    margin-top: 10px;
    padding: 7px 18px;
    border: 1px solid rgba(240,234,224,0.6);
    color: #F0EAE0;
    font-family: 'Inter', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 1px;
    transition: background 0.25s;
    align-self: flex-start;
  }
  .aura-mini-banner-item:hover .aura-mini-banner-cta {
    background: rgba(184,151,106,0.5);
    border-color: #B8976A;
  }
  /* Placeholder sem imagem */
  .aura-mini-banner-placeholder {
    width: 100%;
    height: {{ section.settings.item_height }}px;
    background: linear-gradient(135deg, #E8E0D4, #C9B99A);
    display: flex; align-items: center; justify-content: center;
  }
  @media (max-width: 749px) {
    .aura-mini-banners__inner {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .aura-mini-banner-item img,
    .aura-mini-banner-placeholder { height: 200px; }
  }
  @media (min-width: 750px) and (max-width: 989px) {
    .aura-mini-banners__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="aura-mini-banners">
  <div class="aura-mini-banners__inner">
    {% for block in section.blocks %}
      <{% if block.settings.link != blank %}a href="{{ block.settings.link }}"{% if block.settings.open_new_tab %} target="_blank" rel="noopener"{% endif %}{% else %}div{% endif %} class="aura-mini-banner-item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                    {{ block.settings.image | image_url: width: 600 }} 600w,
                    {{ block.settings.image | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 100vw, 33vw"
            alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {%- else -%}
          <div class="aura-mini-banner-placeholder">
            <span style="font-family:'Cormorant Garamond',serif;color:#A68B6B;font-size:1.1rem;letter-spacing:0.1em;">Imagem {{ forloop.index }}</span>
          </div>
        {%- endif -%}
        <div class="aura-mini-banner-overlay">
          {% if block.settings.label != blank %}<p class="aura-mini-banner-label">{{ block.settings.label }}</p>{% endif %}
          {% if block.settings.sublabel != blank %}<p class="aura-mini-banner-sub">{{ block.settings.sublabel }}</p>{% endif %}
          {% if block.settings.cta != blank %}<span class="aura-mini-banner-cta">{{ block.settings.cta }}</span>{% endif %}
        </div>
      </{% if block.settings.link != blank %}a{% else %}div{% endif %}>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Aura — Mini Banners",
  "blocks": [
    {
      "type": "banner",
      "name": "Mini Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Título",
          "default": "Categoria"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Subtítulo"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "Texto do botão",
          "default": "Ver coleção"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Abrir em nova aba",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo da seção",
      "default": "#F0EAE0"
    },
    {
      "type": "range",
      "id": "item_height",
      "min": 180,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Altura dos banners",
      "default": 320
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Espaço entre banners",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "label": "Arredondamento",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Espaço superior",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Espaço inferior",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Aura — Mini Banners",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}

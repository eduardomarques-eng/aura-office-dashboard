{% comment %}
  Aura Decore — Featured Collection Section
  Renderiza produtos reais de uma coleção Shopify
  Japandi × Minimalismo | Sprint 2
{% endcomment %}

{%- liquid
  assign collection = section.settings.collection
  assign products_count = section.settings.products_to_show | default: 4
  assign columns = section.settings.columns_desktop | default: 4
-%}

<div
  class="aura-featured-col"
  id="AuraFeaturedCol-{{ section.id }}"
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">

    {%- if section.settings.kicker != blank or section.settings.title != blank -%}
    <div class="aura-featured-col__header" data-aura-reveal>
      {%- if section.settings.kicker != blank -%}
        <span class="kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="aura-featured-col__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="aura-featured-col__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    <ul
      class="aura-featured-col__grid"
      style="grid-template-columns: repeat({{ columns }}, 1fr);"
      role="list"
    >
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_count -%}
          <li
            class="aura-featured-col__item"
            data-aura-reveal="delay-{{ forloop.index }}"
          >
            <div class="card-wrapper product-card-wrapper">
              <a
                href="{{ product.url }}"
                class="aura-product-card"
                aria-label="{{ product.title | escape }}"
              >
                {%- if product.featured_image -%}
                <div class="aura-product-card__media">
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 375 }} 375w,
                      {{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w
                    "
                    sizes="(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="600" height="720"
                    loading="lazy"
                    class="aura-product-card__img"
                  >
                  {%- if product.images.size > 1 -%}
                  <img
                    src="{{ product.images[1] | image_url: width: 600 }}"
                    alt="{{ product.images[1].alt | default: product.title | escape }}"
                    width="600" height="720"
                    loading="lazy"
                    class="aura-product-card__img aura-product-card__img--hover"
                    aria-hidden="true"
                  >
                  {%- endif -%}

                  {%- if product.compare_at_price > product.price -%}
                  <span class="badge badge--sale">Promoção</span>
                  {%- elsif product.tags contains 'lancamento' -%}
                  <span class="badge badge--new" style="background:var(--aura-musgo);color:#fff;">Novo</span>
                  {%- elsif product.tags contains 'mais-amado' -%}
                  <span class="badge badge--fav" style="background:var(--aura-terracota);color:#fff;">♡ Favorito</span>
                  {%- endif -%}

                  <div class="aura-product-card__quick-add">
                    <button
                      type="button"
                      class="button button--secondary aura-quick-add-btn"
                      data-product-handle="{{ product.handle }}"
                      aria-label="Adicionar {{ product.title | escape }}"
                    >
                      Adicionar ao carrinho
                    </button>
                  </div>
                </div>
                {%- else -%}
                <div class="aura-product-card__media aura-product-card__media--placeholder" style="background:var(--aura-linen);aspect-ratio:5/6;"></div>
                {%- endif -%}

                <div class="aura-product-card__info">
                  {%- if product.vendor != blank -%}
                  <p class="aura-product-card__vendor">{{ product.vendor }}</p>
                  {%- endif -%}
                  <h3 class="aura-product-card__title">{{ product.title }}</h3>
                  <div class="aura-product-card__price">
                    {%- if product.compare_at_price > product.price -%}
                      <s class="aura-product-card__price-compare">{{ product.compare_at_price | money }}</s>
                      <span class="aura-product-card__price-sale">{{ product.price | money }}</span>
                    {%- else -%}
                      <span>{{ product.price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </div>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_count) -%}
        <li class="aura-featured-col__item">
          <div class="aura-product-card aura-product-card--placeholder">
            <div class="aura-product-card__media" style="background:var(--aura-linen);aspect-ratio:5/6;"></div>
            <div class="aura-product-card__info">
              <p class="aura-product-card__vendor">Aura Decore</p>
              <h3 class="aura-product-card__title">Produto em breve</h3>
              <div class="aura-product-card__price"><span>—</span></div>
            </div>
          </div>
        </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>

    {%- if section.settings.show_view_all and collection != blank -%}
    <div class="aura-featured-col__cta" data-aura-reveal>
      <a href="{{ collection.url }}" class="button button--secondary">
        {{ section.settings.view_all_label | default: 'Ver toda a coleção' }}
      </a>
    </div>
    {%- endif -%}

  </div>
</div>

<style>
  .aura-featured-col__header {
    text-align: center;
    margin-bottom: 5.6rem;
  }
  .aura-featured-col__title {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 4vw, 4.4rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--aura-grafite);
    margin: 0 0 1.6rem;
  }
  .aura-featured-col__desc {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--aura-cinza);
    max-width: 56rem;
    margin: 0 auto;
    line-height: 1.8;
  }
  .aura-featured-col__grid {
    display: grid;
    gap: 2.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (max-width: 1023px) {
    .aura-featured-col__grid { grid-template-columns: repeat(2, 1fr) !important; gap: 1.6rem; }
  }
  @media (max-width: 549px) {
    .aura-featured-col__grid { grid-template-columns: repeat(2, 1fr) !important; gap: 1.2rem; }
  }

  .aura-product-card {
    display: block;
    text-decoration: none;
    color: var(--aura-grafite);
  }
  .aura-product-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 5/6;
    background: var(--aura-cream);
    margin-bottom: 1.6rem;
  }
  .aura-product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 560ms cubic-bezier(0.16,1,0.3,1);
    display: block;
  }
  .aura-product-card__img--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 400ms ease, transform 560ms cubic-bezier(0.16,1,0.3,1);
  }
  .aura-product-card:hover .aura-product-card__img:not(.aura-product-card__img--hover) {
    transform: scale(1.04);
  }
  .aura-product-card:hover .aura-product-card__img--hover {
    opacity: 1;
  }
  .badge {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    z-index: 2;
  }
  .aura-product-card__quick-add {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.6rem;
    transform: translateY(100%);
    transition: transform 360ms cubic-bezier(0.16,1,0.3,1);
    z-index: 3;
  }
  .aura-product-card:hover .aura-product-card__quick-add {
    transform: translateY(0);
  }
  .aura-quick-add-btn {
    width: 100%;
    background: rgba(250,250,248,0.92) !important;
    backdrop-filter: blur(4px);
    font-size: 1.1rem;
    padding: 1.2rem 2rem;
  }
  .aura-product-card__info { padding: 0 0.4rem; }
  .aura-product-card__vendor {
    font-family: var(--font-sans);
    font-size: 1rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aura-cinza);
    margin: 0 0 0.4rem;
  }
  .aura-product-card__title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 0.8rem;
    color: var(--aura-grafite);
  }
  .aura-product-card__price {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--aura-grafite-soft);
  }
  .aura-product-card__price-compare {
    color: var(--aura-cinza);
    text-decoration: line-through;
    margin-right: 0.8rem;
  }
  .aura-product-card__price-sale { color: var(--aura-terracota); }
  .aura-featured-col__cta {
    text-align: center;
    margin-top: 4.8rem;
  }
</style>

{% schema %}
{
  "name": "Aura Coleção Destaque",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2, "max": 12, "step": 2,
      "label": "Produtos a exibir",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colunas (desktop)",
      "options": [
        { "value": "2", "label": "2 colunas" },
        { "value": "3", "label": "3 colunas" },
        { "value": "4", "label": "4 colunas" }
      ],
      "default": "4"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Mais Amados"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Descrição"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar link 'Ver tudo'",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Texto do link",
      "default": "Ver toda a coleção"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 8,
      "unit": "px",
      "label": "Padding superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 8,
      "unit": "px",
      "label": "Padding inferior",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Aura Coleção Destaque",
      "settings": {
        "kicker": "Curadoria",
        "title": "Mais Amados",
        "products_to_show": 4,
        "columns_desktop": "4",
        "show_view_all": true
      }
    }
  ]
}
{% endschema %}

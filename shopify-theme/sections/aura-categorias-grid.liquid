{% comment %}
  Aura Decore — Grid de Categorias com ícone/imagem
  Equivalente ao menu visual de categorias da Dcorada
{% endcomment %}

<style>
  .aura-categorias {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }
  .aura-categorias__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .aura-categorias__titulo {
    text-align: center;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: {{ section.settings.title_color }};
    margin: 0 0 32px;
  }
  .aura-categorias__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }
  .aura-categoria-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: 20px 10px;
    background: {{ section.settings.card_bg }};
    border: 1px solid rgba(26,26,26,0.06);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .aura-categoria-item:hover {
    border-color: var(--aura-primary, #B8976A);
    box-shadow: 0 4px 16px rgba(26,26,26,0.07);
    transform: translateY(-2px);
  }
  .aura-categoria-item__img-wrap {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background: #F0EAE0;
    margin-bottom: 12px;
    flex-shrink: 0;
  }
  .aura-categoria-item__img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
  }
  .aura-categoria-item__nome {
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    margin: 0;
    transition: color 0.2s;
  }
  .aura-categoria-item:hover .aura-categoria-item__nome {
    color: var(--aura-primary, #B8976A);
  }
  @media (max-width: 749px) {
    .aura-categorias__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .aura-categoria-item { padding: 14px 6px; }
    .aura-categoria-item__img-wrap { width: 60px; height: 60px; }
  }
  @media (max-width: 480px) {
    .aura-categorias__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<div class="aura-categorias">
  <div class="aura-categorias__inner">
    {% if section.settings.titulo != blank %}
    <h2 class="aura-categorias__titulo">{{ section.settings.titulo }}</h2>
    {% endif %}
    <div class="aura-categorias__grid">
      {% for block in section.blocks %}
        {% if block.type == 'categoria' %}
        <a {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
           class="aura-categoria-item"
           {{ block.shopify_attributes }}>
          <div class="aura-categoria-item__img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 200 }}"
                   alt="{{ block.settings.nome | escape }}"
                   loading="lazy"
                   width="{{ section.settings.icon_size }}"
                   height="{{ section.settings.icon_size }}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#E8E0D4,#C9B99A);"></div>
            {% endif %}
          </div>
          <p class="aura-categoria-item__nome">{{ block.settings.nome }}</p>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Aura — Categorias Grid",
  "blocks": [
    {
      "type": "categoria",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem/ícone da categoria"
        },
        {
          "type": "text",
          "id": "nome",
          "label": "Nome da categoria",
          "default": "Categoria"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link da categoria"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da seção",
      "default": "Explore por Categoria"
    },
    {
      "type": "range",
      "id": "cols",
      "min": 4,
      "max": 8,
      "step": 1,
      "label": "Colunas (desktop)",
      "default": 6
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 60,
      "max": 140,
      "step": 10,
      "unit": "px",
      "label": "Tamanho da imagem",
      "default": 90
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Espaço entre itens",
      "default": 16
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fundo da seção",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fundo do card",
      "default": "#F9F7F4"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#2D2D2D"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaço superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espaço inferior",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Aura — Categorias Grid",
      "blocks": [
        { "type": "categoria", "settings": { "nome": "Sala" } },
        { "type": "categoria", "settings": { "nome": "Quarto" } },
        { "type": "categoria", "settings": { "nome": "Cozinha" } },
        { "type": "categoria", "settings": { "nome": "Banheiro" } },
        { "type": "categoria", "settings": { "nome": "Jardim" } },
        { "type": "categoria", "settings": { "nome": "Escritório" } }
      ]
    }
  ]
}
{% endschema %}

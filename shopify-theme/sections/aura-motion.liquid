<style>
  .aura-motion {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #1A1A1A;
    padding: 0;
  }
  .aura-motion__video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .aura-motion__video-wrap iframe,
  .aura-motion__video-wrap video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    border: none;
    object-fit: cover;
  }
  .aura-motion__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      180deg,
      rgba(26,26,26,0.1) 0%,
      rgba(26,26,26,0.0) 30%,
      rgba(26,26,26,0.0) 50%,
      rgba(26,26,26,0.35) 80%,
      rgba(26,26,26,0.7) 100%
    );
    pointer-events: none;
  }
  .aura-motion__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    padding: 48px 60px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }
  .aura-motion__text {
    max-width: 560px;
  }
  .aura-motion__label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
    font-weight: 400;
    opacity: 0;
    animation: auraMotionFadeUp 0.8s ease 0.3s forwards;
  }
  .aura-motion__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.8rem;
    font-weight: 300;
    color: #FAF8F5;
    line-height: 1.15;
    margin-bottom: 14px;
    letter-spacing: 0.02em;
    opacity: 0;
    animation: auraMotionFadeUp 0.8s ease 0.5s forwards;
  }
  .aura-motion__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin-bottom: 28px;
    opacity: 0;
    animation: auraMotionFadeUp 0.8s ease 0.7s forwards;
  }
  .aura-motion__btn {
    display: inline-block;
    padding: 14px 40px;
    border: 1px solid rgba(255,255,255,0.5);
    color: #FAF8F5;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.4s ease;
    opacity: 0;
    animation: auraMotionFadeUp 0.8s ease 0.9s forwards;
    font-family: 'Inter', sans-serif;
  }
  .aura-motion__btn:hover {
    background: #FAF8F5;
    color: #1A1A1A;
    border-color: #FAF8F5;
  }
  .aura-motion__badge {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    opacity: 0;
    animation: auraMotionFadeUp 0.8s ease 1.1s forwards;
  }
  .aura-motion__badge-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: rgba(255,255,255,0.7);
    animation: auraMotionPulse 2.5s ease-in-out infinite;
  }
  .aura-motion__badge-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    font-weight: 400;
  }
  /* Decorative floating particles */
  .aura-motion__particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .aura-motion__particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: rgba(184,151,106,0.4);
    border-radius: 50%;
    animation: auraMotionFloat linear infinite;
  }
  .aura-motion__particle:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; }
  .aura-motion__particle:nth-child(2) { left: 25%; animation-duration: 15s; animation-delay: 2s; width: 2px; height: 2px; }
  .aura-motion__particle:nth-child(3) { left: 45%; animation-duration: 10s; animation-delay: 4s; }
  .aura-motion__particle:nth-child(4) { left: 65%; animation-duration: 14s; animation-delay: 1s; width: 4px; height: 4px; }
  .aura-motion__particle:nth-child(5) { left: 80%; animation-duration: 11s; animation-delay: 3s; }
  .aura-motion__particle:nth-child(6) { left: 92%; animation-duration: 13s; animation-delay: 5s; width: 2px; height: 2px; }
  /* Progress bar at bottom */
  .aura-motion__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, #B8976A, #C4846C);
    z-index: 4;
    animation: auraMotionProgress 30s linear infinite;
  }
  @keyframes auraMotionFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes auraMotionFloat {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
  }
  @keyframes auraMotionPulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.08); opacity: 1; }
  }
  @keyframes auraMotionProgress {
    0% { width: 0%; }
    100% { width: 100%; }
  }
  @media (max-width: 768px) {
    .aura-motion__content {
      flex-direction: column;
      padding: 32px 24px;
      align-items: flex-start;
    }
    .aura-motion__title { font-size: 2rem; }
    .aura-motion__subtitle { font-size: 0.85rem; }
    .aura-motion__badge { display: none; }
  }
</style>

<section class="aura-motion">
  <div class="aura-motion__video-wrap">
    {% if section.settings.video_url != blank %}
      <iframe 
        src="{{ section.settings.video_url }}" 
        allow="autoplay; encrypted-media; fullscreen"
        allowfullscreen
        loading="lazy"
        title="{{ section.settings.heading | escape }}"
      ></iframe>
    {% else %}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#2D2D2D 0%,#1A1A1A 50%,#2D2D2D 100%);display:flex;align-items:center;justify-content:center;">
        <div style="text-align:center;color:rgba(255,255,255,0.3);">
          <p style="font-size:2rem;margin-bottom:8px;">▶</p>
          <p style="font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;">Adicione um vídeo nas configurações</p>
        </div>
      </div>
    {% endif %}
  </div>
  <div class="aura-motion__overlay"></div>
  <div class="aura-motion__particles">
    <span class="aura-motion__particle"></span>
    <span class="aura-motion__particle"></span>
    <span class="aura-motion__particle"></span>
    <span class="aura-motion__particle"></span>
    <span class="aura-motion__particle"></span>
    <span class="aura-motion__particle"></span>
  </div>
  <div class="aura-motion__content">
    <div class="aura-motion__text">
      <p class="aura-motion__label">{{ section.settings.label }}</p>
      <h2 class="aura-motion__title">{{ section.settings.heading }}</h2>
      <p class="aura-motion__subtitle">{{ section.settings.description }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="aura-motion__btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    <div class="aura-motion__badge">
      <div class="aura-motion__badge-icon">✦</div>
      <div class="aura-motion__badge-text">Motion<br>Design</div>
    </div>
  </div>
  <div class="aura-motion__progress"></div>
</section>

{% schema %}
{
  "name": "Aura Motion Design",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "A M B I E N T E   A C O N C H E G A N T E"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Encontre seu Refúgio"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Um ambiente pensado para quem busca paz na beleza dos detalhes. Texturas naturais, tons terrosos e a luz perfeita."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "EXPLORAR COLEÇÃO"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video embed URL (YouTube ou Canva)",
      "info": "Cole a URL de embed. YouTube: https://www.youtube.com/embed/VIDEO_ID?autoplay=1&mute=1&loop=1&playlist=VIDEO_ID | Canva: https://www.canva.com/design/ID/watch?embed",
      "default": "https://www.youtube.com/embed/qsOUv9EzKsg?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&playlist=qsOUv9EzKsg"
    }
  ],
  "presets": [
    {
      "name": "Aura Motion Design"
    }
  ]
}
{% endschema %}
